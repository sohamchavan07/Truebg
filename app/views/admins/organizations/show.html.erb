<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900"><%= @organization.name %></h1>
    <p class="text-gray-500"><%= @organization.website %></p>
  </div>
  <%= link_to "Back to Organizations", admins_organizations_path, class: "text-blue-600 hover:underline" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
  <div class="md:col-span-1">
    <div class="bg-white rounded-lg shadow p-6 mb-8">
      <h2 class="text-lg font-semibold mb-4 border-b pb-2">Organization Details</h2>
      <div class="space-y-3 text-sm">
        <div><span class="text-gray-500 block">Email:</span> <%= @organization.email %></div>
        <div><span class="text-gray-500 block">Phone:</span> <%= @organization.phone %></div>
        <div><span class="text-gray-500 block">Address:</span> <%= @organization.address %></div>
      </div>
    </div>
  </div>

  <div class="md:col-span-2">
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b bg-gray-50">
        <h2 class="text-lg font-semibold">Verification Cases</h2>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Candidate</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @verification_cases.each do |vc| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900"><%= vc.candidate.full_name %></div>
                <div class="text-sm text-gray-500"><%= vc.candidate.email %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_badge_class(vc.status) %>">
                  <%= vc.status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "View Case", admins_verification_case_path(vc), class: "text-blue-600 hover:text-blue-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
