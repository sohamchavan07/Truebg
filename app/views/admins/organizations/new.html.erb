<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <%= link_to "← Back to Organizations", admins_organizations_path, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
    <h1 class="text-3xl font-bold mt-2">New Organization</h1>
  </div>

  <div class="bg-white rounded-lg shadow-md p-8">
    <%= form_with(model: [:admins, @organization], local: true) do |f| %>
      <div class="space-y-6">
        <div>
          <%= f.label :name, "Organization Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, required: true, class: "w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "Acme Corp" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :email, "Contact Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.email_field :email, class: "w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "hr@acme.com" %>
          </div>
          <div>
            <%= f.label :phone, "Phone Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :phone, class: "w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "+1 234 567 890" %>
          </div>
        </div>

        <div>
          <%= f.label :website, "Website", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.url_field :website, class: "w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "https://www.acme.com" %>
        </div>

        <div>
          <%= f.label :address, "Office Address", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :address, rows: 3, class: "w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500", placeholder: "123 Business St, Suite 100" %>
        </div>

        <div class="pt-4">
          <%= f.submit "Create Organization", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-md shadow-sm transition duration-150" %>
        </div>
      </div>
    <% end %>
  </div>
</div>