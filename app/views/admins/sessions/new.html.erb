<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login</title>
  <style>
    body {
      margin: 0;
      font-family: "Inter", Arial, sans-serif;
      background: linear-gradient(135deg, #f3f0ff, #e8f0ff);
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      flex-direction: column;
    }

    .logo {
      font-family: "Brush Script MT", cursive;
      font-size: 32px;
      font-weight: bold;
      margin-bottom: 20px;
      color: #333;
    }

    .login-box {
      background: #fff;
      padding: 32px 28px;
      border-radius: 12px;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
      text-align: left;
      width: 320px;
    }

    .login-box h2 {
      margin: 0 0 24px 0;
      font-size: 18px;
      font-weight: 500;
      color: #222;
    }

    .login-box h2 span {
      color: #4f46e5;
      font-weight: 600;
      cursor: pointer;
    }

    .field {
      margin-bottom: 18px;
      position: relative;
    }

    .field input {
      width: 100%;
      padding: 12px 40px 12px 40px;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 14px;
      box-sizing: border-box;
    }

    .field input:focus {
      outline: none;
      border-color: #4f46e5;
      box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.15);
    }

    .field i {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      color: #888;
      font-size: 14px;
    }

    .field .icon-left {
      left: 12px;
    }

    .field .icon-right {
      right: 12px;
      cursor: pointer;
    }

    .login-box button {
      width: 100%;
      padding: 12px;
      background: #6d28d9;
      border: none;
      border-radius: 6px;
      color: #fff;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }

    .login-box button:hover {
      background: #4c1d95;
    }

    .footer {
      margin-top: 32px;
      text-align: center;
      font-size: 12px;
      color: #666;
    }

    .footer .logo-footer {
      font-family: "Brush Script MT", cursive;
      font-size: 22px;
      margin-bottom: 6px;
      display: block;
    }
  </style>
  <!-- For icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

<div class="logo">
  <%= image_tag 'logo.svg', alt: 'Truebg', width: 440, height: 32 %>
  </div>
  <div class="login-box">
    <h2>Welcome, <span>Soham!</span> 👋</h2>

    <div class="field">
      <i class="fa-regular fa-envelope icon-left"></i>
      <input type="email" placeholder="Enter your email">
    </div>

    <div class="field">
      <i class="fa-solid fa-lock icon-left"></i>
      <input type="password" id="password" placeholder="Enter your password">
      <i class="fa-regular fa-eye icon-right" id="togglePassword"></i>
    </div>

    <button>Log in</button>
  </div>

  <div class="footer">
  <div class="logo">

  <%= image_tag 'logo.svg', alt: 'Truebg', width: 440, height: 32 %>
  </div>    <p>Copyright © 2025 Truebg. All Rights Reserved.</p>
  </div>

  <script>
    const togglePassword = document.getElementById("togglePassword");
    const passwordInput = document.getElementById("password");

    togglePassword.addEventListener("click", () => {
      const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
      passwordInput.setAttribute("type", type);

      // toggle eye / eye-slash icon
      togglePassword.classList.toggle("fa-eye");
      togglePassword.classList.toggle("fa-eye-slash");
    });
  </script>
</body>
</html>
