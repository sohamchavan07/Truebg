<div class="mb-8 flex justify-between items-center">
  <div>
    <%= link_to "← Back to Cases", admins_verification_cases_path, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
    <h1 class="text-3xl font-bold mt-2">Case #<%= @verification_case.id %></h1>
  </div>
    <div class="flex space-x-4">
      <span class="px-4 py-2 inline-flex text-sm leading-5 font-semibold rounded-full <%= status_badge_class(@verification_case.status) %>">
        <%= @verification_case.status.titleize %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-8">
      <!-- Candidate Details -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
          <h2 class="text-lg font-bold text-gray-800">Candidate Information</h2>
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <p class="text-xs text-gray-500 uppercase font-medium">Full Name</p>
              <p class="text-gray-900 font-medium"><%= @verification_case.candidate.full_name.presence || "Not Provided" %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500 uppercase font-medium">Email Address</p>
              <p class="text-gray-900 font-medium"><%= @verification_case.candidate.email %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500 uppercase font-medium">Phone Number</p>
              <p class="text-gray-900 font-medium"><%= @verification_case.candidate.phone.presence || "Not Provided" %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500 uppercase font-medium">Date of Birth</p>
              <p class="text-gray-900 font-medium"><%= @verification_case.candidate.dob&.strftime("%b %d, %Y") || "Not Provided" %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500 uppercase font-medium">PAN Number</p>
              <p class="text-gray-900 font-medium"><%= @verification_case.candidate.pan_number.presence || "Not Provided" %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500 uppercase font-medium">Aadhaar Number</p>
              <p class="text-gray-900 font-medium"><%= @verification_case.candidate.aadhaar_number.presence || "Not Provided" %></p>
            </div>
            <div class="md:col-span-2">
              <p class="text-xs text-gray-500 uppercase font-medium">Address</p>
              <p class="text-gray-900 font-medium"><%= @verification_case.candidate.address.presence || "Not Provided" %></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Work History -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
          <h2 class="text-lg font-bold text-gray-800">Work Experience</h2>
        </div>
        <div class="p-6">
          <% if @verification_case.candidate.work_histories.any? %>
            <div class="space-y-6">
              <% @verification_case.candidate.work_histories.each do |work| %>
                <div class="border-l-4 border-purple-200 pl-4 py-1">
                  <div class="flex justify-between items-start">
                    <div>
                      <h3 class="font-bold text-gray-900"><%= work.job_title %></h3>
                      <p class="text-gray-600 text-sm"><%= work.company_name %></p>
                    </div>
                    <span class="text-xs text-gray-500 font-medium">
                      <%= work.start_date.strftime("%b %Y") %> - <%= work.current_job ? "Present" : work.end_date&.strftime("%b %Y") %>
                    </span>
                  </div>
                  <p class="text-xs text-gray-500 mt-1"><%= work.location %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 italic text-sm text-center py-4">No work experience records found.</p>
          <% end %>
        </div>
      </div>

      <!-- Education History -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
          <h2 class="text-lg font-bold text-gray-800">Education</h2>
        </div>
        <div class="p-6">
          <% if @verification_case.candidate.education_histories.any? %>
            <div class="space-y-6">
              <% @verification_case.candidate.education_histories.each do |edu| %>
                <div class="border-l-4 border-blue-200 pl-4 py-1">
                  <div class="flex justify-between items-start">
                    <div>
                      <h3 class="font-bold text-gray-900"><%= edu.degree %> in <%= edu.field_of_study %></h3>
                      <p class="text-gray-600 text-sm"><%= edu.institution_name %></p>
                    </div>
                    <span class="text-xs text-gray-500 font-medium">Class of <%= edu.graduation_year %></span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 italic text-sm text-center py-4">No education records found.</p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Sidebar Info -->
    <div class="space-y-8">
      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-4">Requesting Organization</h3>
        <div class="flex items-center mb-4">
          <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center text-purple-600 font-bold text-xl mr-4">
            <%= @verification_case.organization.name[0] %>
          </div>
          <div>
            <p class="font-bold text-gray-900"><%= @verification_case.organization.name %></p>
            <p class="text-xs text-gray-500"><%= @verification_case.organization.website %></p>
          </div>
        </div>
        <div class="text-xs text-gray-500 border-t border-gray-100 pt-4 mt-4">
          <p>Contact: <%= @verification_case.organization.email %></p>
          <p>Phone: <%= @verification_case.organization.phone %></p>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-4">Case Summary</h3>
        <%= form_with model: [:admins, @verification_case], class: "space-y-4" do |f| %>
          <div>
            <%= f.label :status, class: "block text-xs text-gray-500 uppercase font-medium mb-1" %>
            <%= f.select :status, VerificationCase::STATUSES.map { |s| [s.titleize, s] }, {}, class: "w-full border-gray-300 rounded-md shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm" %>
          </div>
          <%= f.submit "Update Status", class: "w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded transition duration-150 cursor-pointer" %>
        <% end %>

        <div class="space-y-3 mt-6 border-t pt-4">
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">Case Created</span>
            <span class="font-medium"><%= @verification_case.created_at.strftime("%b %d, %Y") %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">Last Updated</span>
            <span class="font-medium"><%= @verification_case.updated_at.strftime("%b %d, %Y") %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">Completed At</span>
            <span class="font-medium text-green-600"><%= @verification_case.completed_at&.strftime("%b %d, %Y") || "Pending" %></span>
          </div>
        </div>
        <div class="mt-6">
          <button class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded transition duration-150">
            Generate Report
          </button>
        </div>
      </div>
    </div>
  </div>