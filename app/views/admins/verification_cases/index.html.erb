<div class="flex justify-between items-center mb-8">
  <h1 class="text-3xl font-bold">Verification Cases</h1>
  <div class="flex space-x-4">
    <%= link_to "New Case", new_admins_verification_case_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md font-medium transition duration-150 shadow-sm" %>
  </div>
</div>

  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Candidate</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Organization</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @verification_cases.each do |vc| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">
                #<%= vc.id %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900"><%= vc.candidate.full_name.presence || "Pending Setup" %></div>
                <div class="text-sm text-gray-500"><%= vc.candidate.email %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= vc.organization.name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_badge_class(vc.status) %>">
                  <%= vc.status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= vc.created_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "Show", admins_verification_case_path(vc), class: "text-purple-600 hover:text-purple-900 mr-4" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>