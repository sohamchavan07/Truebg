<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900"><%= @candidate.full_name %></h1>
    <p class="text-gray-500"><%= @candidate.email %> • Joined <%= @candidate.created_at.strftime("%B %Y") %></p>
  </div>
  <%= link_to "Back to Candidates", admins_candidates_path, class: "text-blue-600 hover:underline" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
  <div class="md:col-span-1">
    <div class="bg-white rounded-lg shadow p-6 mb-8">
      <h2 class="text-lg font-semibold mb-4 border-b pb-2">Personal Details</h2>
      <div class="space-y-3 text-sm">
        <div><span class="text-gray-500 block">Phone:</span> <%= @candidate.phone %></div>
        <div><span class="text-gray-500 block">DOB:</span> <%= @candidate.dob&.strftime("%b %d, %Y") %></div>
        <div><span class="text-gray-500 block">PAN:</span> <%= @candidate.pan_number %></div>
        <div><span class="text-gray-500 block">Aadhaar:</span> <%= @candidate.aadhaar_number %></div>
        <div><span class="text-gray-500 block">Address:</span> <%= @candidate.address %>, <%= @candidate.city %>, <%= @candidate.state %> - <%= @candidate.pincode %></div>
      </div>
    </div>
  </div>

  <div class="md:col-span-2">
    <div class="bg-white rounded-lg shadow overflow-hidden mb-8">
      <div class="px-6 py-4 border-b bg-gray-50">
        <h2 class="text-lg font-semibold">Verification Cases</h2>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <tbody class="bg-white divide-y divide-gray-200">
          <% @verification_cases.each do |vc| %>
            <tr>
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-gray-900"><%= vc.organization.name %></div>
                <div class="text-xs text-gray-500">Requested: <%= vc.requested_at&.strftime("%b %d, %Y") %></div>
              </td>
              <td class="px-6 py-4">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_badge_class(vc.status) %>">
                  <%= vc.status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 text-right">
                <%= link_to "Details", admins_verification_case_path(vc), class: "text-blue-600 hover:underline text-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden mb-8">
      <div class="px-6 py-4 border-b bg-gray-50">
        <h2 class="text-lg font-semibold">Work History</h2>
      </div>
      <div class="p-6">
        <% @work_histories.each do |work| %>
          <div class="mb-4 pb-4 border-b last:border-0">
            <div class="flex justify-between">
              <h3 class="font-bold text-gray-900"><%= work.company_name %></h3>
              <% if work.verified %>
                <span class="text-green-600 text-xs font-semibold flex items-center">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> Verified
                </span>
              <% end %>
            </div>
            <p class="text-sm text-gray-700"><%= work.job_title %></p>
            <p class="text-xs text-gray-500"><%= work.start_date&.strftime("%b %Y") %> - <%= work.current_job ? "Present" : work.end_date&.strftime("%b %Y") %></p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b bg-gray-50">
        <h2 class="text-lg font-semibold">Education History</h2>
      </div>
      <div class="p-6">
        <% @education_histories.each do |edu| %>
          <div class="mb-4 pb-4 border-b last:border-0">
            <div class="flex justify-between">
              <h3 class="font-bold text-gray-900"><%= edu.institution_name %></h3>
              <% if edu.verified %>
                <span class="text-green-600 text-xs font-semibold flex items-center">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> Verified
                </span>
              <% end %>
            </div>
            <p class="text-sm text-gray-700"><%= edu.degree %> in <%= edu.field_of_study %></p>
            <p class="text-xs text-gray-500">Graduated: <%= edu.graduation_year %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
