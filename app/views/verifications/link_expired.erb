<div class="max-w-md mx-auto">
  <div class="bg-white rounded-[2rem] shadow-xl shadow-gray-200/50 border border-gray-100 overflow-hidden p-12 text-center">
    <div class="inline-flex items-center justify-center p-5 bg-red-50 rounded-3xl mb-8 text-red-500 shadow-sm border border-red-100">
      <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
    </div>
    
    <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight mb-4">Link Expired</h2>
    <p class="text-gray-500 leading-relaxed mb-10">The security window for this verification link has closed. This usually happens after 48 hours or if the link has already been used.</p>
    
    <div class="space-y-6">
      <%= link_to "Request New Link", "#", class: "w-full py-4 px-6 text-white bg-indigo-600 hover:bg-indigo-700 font-bold rounded-2xl shadow-lg shadow-indigo-100 transition-all transform hover:-translate-y-0.5 active:translate-y-0 inline-block" %>
      <div class="pt-4 border-t border-gray-100">
        <p class="text-sm text-gray-400">If you continue to have issues, please reach out directly to your <span class="font-semibold">Hiring Manager</span>.</p>
      </div>
    </div>
  </div>
</div>
