<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Mobile Verification</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @import url('https://fonts.googleapis.com/css?family=Inter:400,600&display=swap');
    body {
      min-height: 100vh;
      margin: 0;
      font-family: 'Inter', Arial, sans-serif;
      background: linear-gradient(135deg, #f8fbff 0%, #f3f6fa 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
    }
    .logo {
      margin-top: 48px;
      margin-bottom: 32px;
      text-align: center;
    }
    .logo img {
      height: 40px;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      padding: 40px 32px 32px 32px;
      max-width: 370px;
      width: 100%;
      margin: 0 auto;
      text-align: center;
      border: 1px solid #ececec;
    }
    .card h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #111;
    }
    .card h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.2rem;
      color: #222;
    }
    .card p {
      font-size: 0.98rem;
      color: #555;
      margin-bottom: 1.5rem;
      line-height: 1.4;
    }
    .otp-inputs {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin-bottom: 24px;
    }
    .otp-inputs input {
      width: 48px;
      height: 48px;
      font-size: 1.5rem;
      text-align: center;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      outline: none;
      transition: border 0.2s;
      background: #fafbfc;
    }
    .otp-inputs input:focus {
      border-color: #111;
    }
    .btn {
      width: 100%;
      padding: 14px 0;
      background: #111;
      color: #fff;
      font-size: 1rem;
      font-weight: 600;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s;
      margin-bottom: 8px;
    }
    .btn:hover {
      background: #222;
    }
    .resend-section {
      margin-top: 32px;
      text-align: center;
      color: #888;
      font-size: 0.98rem;
    }
    .resend-section .resend-link {
      color: #111;
      font-weight: 600;
      cursor: pointer;
      text-decoration: underline;
      margin-left: 8px;
    }
    .footer {
      margin-top: auto;
      text-align: center;
      color: #888;
      font-size: 1rem;
      width: 100%;
      padding-bottom: 32px;
    }
    .footer .brand {
      font-family: 'Pacifico', cursive;
      font-size: 1.2rem;
      color: #888;
      margin-bottom: 4px;
      display: block;
    }
    .footer small {
      display: block;
      margin-top: 2px;
      font-size: 0.85rem;
      color: #aaa;
    }
  </style>
</head>
<body>
  <div class="logo">
    <img src="https://dummyimage.com/180x40/cccccc/000000&text=Logoipsum" alt="Logoipsum" height="40">
  </div>
  <div class="card">
    <h2>Welcome!</h2>
    <h3>Lets get you verified</h3>
    <p>
      We've sent a 5-digit verification code to <%= session[:phone] || '+91 ******1234' %>.<br>
      Please enter it below to continue.
    </p>
    <%= form_with url: verifications_connect_digilocker_path, method: :get, local: true do |f| %>
      <div class="otp-inputs">
        <%= f.text_field :otp_1, maxlength: 1, inputmode: "numeric", pattern: "[0-9]*", required: true %>
        <%= f.text_field :otp_2, maxlength: 1, inputmode: "numeric", pattern: "[0-9]*", required: true %>
        <%= f.text_field :otp_3, maxlength: 1, inputmode: "numeric", pattern: "[0-9]*", required: true %>
        <%= f.text_field :otp_4, maxlength: 1, inputmode: "numeric", pattern: "[0-9]*", required: true %>
        <%= f.text_field :otp_5, maxlength: 1, inputmode: "numeric", pattern: "[0-9]*", required: true %>
      </div>
      <%= f.submit "Verify OTP", class: "btn" %>
    <% end %>
    <div class="resend-section">
      Didn't receive the code? Resend it in (00:34)<br>
      <%= link_to "Resend OTP", verifications_send_otp_path, method: :post, class: "resend-link" %>
    </div>
  </div>
  <div class="footer">
    <div class="brand">Truebg</div>
    <small>Copyright © 2025 Truebg. All Rights Reserved.</small>
  </div>

  <script>
    // Auto-focus next input field when digit is entered
    document.addEventListener('DOMContentLoaded', function() {
      const otpInputs = document.querySelectorAll('.otp-inputs input');
      
      otpInputs.forEach((input, index) => {
        // Only allow numbers
        input.addEventListener('keypress', function(e) {
          const charCode = e.which ? e.which : e.keyCode;
          if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            e.preventDefault();
            return false;
          }
        });
        
        // Prevent paste of non-numeric content
        input.addEventListener('paste', function(e) {
          e.preventDefault();
          const pastedText = (e.clipboardData || window.clipboardData).getData('text');
          const numericText = pastedText.replace(/[^0-9]/g, '');
          if (numericText.length > 0) {
            this.value = numericText.charAt(0);
            if (index < otpInputs.length - 1 && numericText.length > 1) {
              otpInputs[index + 1].value = numericText.charAt(1);
              if (index + 1 < otpInputs.length - 1 && numericText.length > 2) {
                otpInputs[index + 2].value = numericText.charAt(2);
                if (index + 2 < otpInputs.length - 1 && numericText.length > 3) {
                  otpInputs[index + 3].value = numericText.charAt(3);
                  if (index + 3 < otpInputs.length - 1 && numericText.length > 4) {
                    otpInputs[index + 4].value = numericText.charAt(4);
                  }
                }
              }
            }
          }
        });
        
        input.addEventListener('input', function(e) {
          // Remove any non-numeric characters
          this.value = this.value.replace(/[^0-9]/g, '');
          
          if (e.target.value.length === 1) {
            if (index < otpInputs.length - 1) {
              otpInputs[index + 1].focus();
            }
          }
        });
        
        input.addEventListener('keydown', function(e) {
          if (e.key === 'Backspace' && e.target.value === '' && index > 0) {
            otpInputs[index - 1].focus();
          }
        });
      });
    });
  </script>
</body>
</html>