<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Mobile Verification</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @import url('https://fonts.googleapis.com/css?family=Inter:400,600&display=swap');
    body {
      min-height: 100vh;
      margin: 0;
      font-family: 'Inter', Arial, sans-serif;
      background: linear-gradient(135deg, #f8fbff 0%, #f3f6fa 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
    }
    .logo {
      margin-top: 48px;
      margin-bottom: 32px;
      text-align: center;
    }
    .logo img {
      height: 40px;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      padding: 40px 32px 32px 32px;
      max-width: 370px;
      width: 100%;
      margin: 0 auto;
      text-align: center;
      border: 1px solid #ececec;
    }
    .card h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #111;
    }
    .card h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.2rem;
      color: #222;
    }
    .card p {
      font-size: 0.98rem;
      color: #555;
      margin-bottom: 1.5rem;
      line-height: 1.4;
    }
    .otp-inputs {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin-bottom: 24px;
    }
    .otp-inputs input {
      width: 48px;
      height: 48px;
      font-size: 1.5rem;
      text-align: center;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      outline: none;
      transition: border 0.2s;
      background: #fafbfc;
    }
    .otp-inputs input:focus {
      border-color: #111;
    }
    .btn {
      width: 100%;
      padding: 14px 0;
      background: #111;
      color: #fff;
      font-size: 1rem;
      font-weight: 600;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s;
      margin-bottom: 8px;
    }
    .btn:hover {
      background: #222;
    }
    .resend-section {
      margin-top: 32px;
      text-align: center;
      color: #888;
      font-size: 0.98rem;
    }
    .resend-section .resend-link {
      color: #111;
      font-weight: 600;
      cursor: pointer;
      text-decoration: underline;
      margin-left: 8px;
    }
    .footer {
      margin-top: auto;
      text-align: center;
      color: #888;
      font-size: 1rem;
      width: 100%;
      padding-bottom: 32px;
    }
    .footer .brand {
      font-family: 'Pacifico', cursive;
      font-size: 1.2rem;
      color: #888;
      margin-bottom: 4px;
      display: block;
    }
    .footer small {
      display: block;
      margin-top: 2px;
      font-size: 0.85rem;
      color: #aaa;
    }
  </style>
</head>
<body>
  <div class="logo">
    <img src="https://dummyimage.com/180x40/cccccc/000000&text=Logoipsum" alt="Logoipsum" height="40">
  </div>
  <div class="card">
    <h2>Welcome, your name!</h2>
    <h3>Lets get you verified</h3>
    <p>
      We've sent a 5-digit verification code to +91 ******1234.<br>
      Please enter it below to continue.
    </p>
    <form>
      <div class="otp-inputs">
        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" required>
      </div>
      <button type="submit" class="btn">Verify OTP</button>
    </form>
    <div class="resend-section">
      Didn't receive the code? Resend it in (00:34)<br>
      <span class="resend-link">Resend OTP</span>
    </div>
  </div>
  <div class="footer">
    <div class="brand">Truebg</div>
    <small>Copyright © 2025 Truebg. All Rights Reserved.</small>
  </div>
</body>
</html>