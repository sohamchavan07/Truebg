<div class="max-w-md mx-auto py-12 px-4 animate-fade-in">
  <!-- Header -->
  <div class="mb-8 text-center">
    <div class="inline-flex items-center justify-center p-4 bg-white rounded-3xl shadow-xl shadow-indigo-100 border border-indigo-50 mb-6 group transition-transform hover:scale-110 duration-500">
      <svg class="w-10 h-10 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
    </div>
    <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-4">Legal Consent</h1>
    <p class="text-xs text-slate-500 max-w-sm mx-auto">Please authorize the background verification request instituted by your employer.</p>
  </div>

  <div class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl shadow-indigo-100/50 border border-white overflow-hidden">
    <div class="p-10">

      <%= form_with url: verifications_submit_consent_path, method: :post, data: { turbo: false }, class: "space-y-6" do |f| %>
        
        <div class="bg-indigo-50/50 border border-indigo-100 p-4 rounded-2xl text-xs text-slate-600 leading-relaxed max-h-40 overflow-y-auto mb-6">
          <p class="mb-2"><strong>Background Check Authorization:</strong></p>
          <p class="mb-2">I hereby authorize Truebg and its agents to conduct a comprehensive background verification, which may include employment history, education records, identity checks, and any other relevant background information.</p>
          <p>I consent to the collection, storage, and processing of my personal data for the purpose of this background check. My IP address (<%= request.remote_ip %>) and timestamp will be logged as proof of this digitally signed consent.</p>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 pt-1">
            <%= f.check_box :consent_given, class: "w-5 h-5 rounded text-indigo-600 focus:ring-indigo-500 border-slate-300", required: true %>
          </div>
          <%= f.label :consent_given, "I agree to the terms and authorize the background check.", class: "text-sm text-slate-700 font-medium cursor-pointer" %>
        </div>

        <div class="space-y-2 group">
          <%= f.label :signature_text, "Digital Signature (Type your full name)", class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
          <%= f.text_field :signature_text, placeholder: "e.g., John Doe", class: "w-full px-5 py-5 bg-slate-50/50 border border-slate-100 rounded-[1.5rem] focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-xl font-bold text-slate-700", required: true %>
        </div>

        <div class="pt-4">
          <%= f.submit "Agree & Continue", class: "w-full py-5 px-6 text-white bg-indigo-600 hover:bg-indigo-700 font-bold rounded-2xl shadow-lg shadow-indigo-100 transition-all transform hover:-translate-y-0.5 active:translate-y-0 cursor-pointer flex items-center justify-center gap-2 group text-lg" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-8 flex items-center justify-center gap-3 text-slate-400 group">
    <div class="p-2 bg-slate-100 rounded-full group-hover:bg-indigo-50 group-hover:text-indigo-500 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
    </div>
    <span class="text-xs font-bold uppercase tracking-[0.15em]"><%= request.remote_ip %> • <%= Time.current.strftime("%b %d, %Y") %></span>
  </div>
</div>

<style>
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
</style>
