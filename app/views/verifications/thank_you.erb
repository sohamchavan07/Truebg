<div class="max-w-2xl mx-auto py-20 px-4 animate-fade-in text-center">
  <!-- Success Celebration -->
  <div class="mb-12">
    <div class="inline-flex items-center justify-center w-24 h-24 bg-green-50 rounded-[2.5rem] shadow-2xl shadow-green-100 border border-green-100 mb-8 group relative">
      <div class="absolute inset-0 bg-green-400 rounded-[2.5rem] animate-ping opacity-20 group-hover:opacity-40 transition-opacity"></div>
      <svg class="w-12 h-12 text-green-600 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
    </div>
    
    <h1 class="text-5xl font-black text-slate-900 tracking-tight mb-6 mt-4">Verification Submitted!</h1>
    <p class="text-xl text-slate-500 font-medium max-w-lg mx-auto leading-relaxed">
      You've completed the verification process. Our automated systems and audit teams are now processing your credentials.
    </p>
  </div>

  <div class="bg-white/80 backdrop-blur-xl rounded-[3rem] shadow-2xl shadow-indigo-100/30 border border-white p-12 mb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="p-6 rounded-[2rem] bg-slate-50/50 border border-slate-100/50 group hover:bg-white hover:shadow-xl hover:shadow-indigo-50 transition-all duration-500">
        <div class="text-2xl mb-4">⚡</div>
        <h4 class="text-sm font-black text-slate-900 mb-1">Instant Scan</h4>
        <p class="text-[10px] text-slate-400 uppercase tracking-widest font-bold">Identity Check</p>
        <div class="mt-4 flex items-center justify-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
          <span class="text-[10px] font-black text-green-600 uppercase tracking-[0.1em]">Complete</span>
        </div>
      </div>
      
      <div class="p-6 rounded-[2rem] bg-indigo-50/30 border border-indigo-100/30 group hover:bg-white hover:shadow-xl hover:shadow-indigo-50 transition-all duration-500 scale-105 shadow-xl shadow-indigo-100/20 ring-4 ring-indigo-50/50">
        <div class="text-2xl mb-4">🔍</div>
        <h4 class="text-sm font-black text-slate-900 mb-1">In Progress</h4>
        <p class="text-[10px] text-slate-400 uppercase tracking-widest font-bold">Deep Compliance</p>
        <div class="mt-4 flex items-center justify-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
          <span class="text-[10px] font-black text-indigo-600 uppercase tracking-[0.1em]">Scanning</span>
        </div>
      </div>

      <div class="p-6 rounded-[2rem] bg-slate-50/50 border border-slate-100/50 group hover:bg-white hover:shadow-xl hover:shadow-indigo-50 transition-all duration-500">
        <div class="text-2xl mb-4">📄</div>
        <h4 class="text-sm font-black text-slate-400 mb-1">Pending</h4>
        <p class="text-[10px] text-slate-300 uppercase tracking-widest font-bold">Report Issuance</p>
        <div class="mt-4 flex items-center justify-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span>
          <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.1em]">Queued</span>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-10 border-t border-slate-50">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="text-left">
          <p class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-1">Official Reference</p>
          <p class="text-sm font-bold text-indigo-600">REQ-<%= SecureRandom.hex(4).upcase %></p>
        </div>
        <%= link_to verifications_your_profile_path, class: "px-8 py-4 bg-slate-900 text-white font-black rounded-2xl text-xs uppercase tracking-[0.2em] shadow-2xl shadow-slate-900/30 hover:bg-indigo-600 hover:scale-105 active:scale-95 transition-all" do %>
          Re-view Submitted Details
        <% end %>
      </div>
    </div>
  </div>

  <p class="text-xs font-bold text-slate-400">
    Need assistance? <a href="#" class="text-indigo-500 hover:text-indigo-700 underline decoration-indigo-200 underline-offset-4">Contact our Support Command</a>
  </p>
</div>

<style>
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
  animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
</style>
