<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Mobile Verification</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      min-height: 100vh;
      margin: 0;
      font-family: 'Inter', Arial, sans-serif;
      background: linear-gradient(135deg, #f8fbff 0%, #f3f6fa 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
    }
    .logo {
      margin-top: 48px;
      margin-bottom: 32px;
      text-align: center;
    }
    .logo img {
      height: 40px;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      padding: 40px 32px 32px 32px;
      max-width: 370px;
      width: 100%;
      margin: 0 auto;
      text-align: center;
      border: 1px solid #ececec;
    }
    .card h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #111;
    }
    .card h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.2rem;
      color: #222;
    }
    .card p {
      font-size: 0.98rem;
      color: #555;
      margin-bottom: 1.5rem;
      line-height: 1.4;
    }
    .input-group {
      margin-bottom: 1.2rem;
    }
    .input-group input {
      width: 100%;
      padding: 12px 14px;
      font-size: 1rem;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      outline: none;
      transition: border 0.2s;
    }
    .input-group input:focus {
      border-color: #111;
    }
    .btn {
      width: 100%;
      padding: 12px 0;
      background: #111;
      color: #fff;
      font-size: 1rem;
      font-weight: 600;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn:hover {
      background: #222;
    }
    .footer {
      margin-top: auto;
      text-align: center;
      color: #888;
      font-size: 1rem;
      width: 100%;
      padding-bottom: 32px;
    }
    .footer .brand {
      font-family: 'Pacifico', cursive;
      font-size: 1.2rem;
      color: #888;
      margin-bottom: 4px;
      display: block;
    }
    .footer small {
      display: block;
      margin-top: 2px;
      font-size: 0.85rem;
      color: #aaa;
    }
    .privacy-card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      padding: 24px 20px;
      max-width: 370px;
      width: 100%;
      margin: 24px auto 0 auto;
      text-align: center;
      border: 1px solid #ececec;
    }
    .privacy-card h4 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 12px;
      color: #111;
    }
    .privacy-card p {
      font-size: 0.9rem;
      color: #555;
      margin-bottom: 8px;
      line-height: 1.4;
    }
    .privacy-card a {
      color: #111;
      font-weight: 600;
      text-decoration: underline;
      margin: 0 4px;
    }
    .privacy-card a:hover {
      color: #333;
    }
  </style>
</head>
<body>
  <div class="logo">
    <img src="https://dummyimage.com/180x40/cccccc/000000&text=Logoipsum" alt="Logoipsum" height="40">
  </div>
  <div class="card">
    <h2>Welcome!</h2>
    <h3>Lets get you verified</h3>
    <p>
      To begin, please verify your mobile number<br>
      This ensures your information remains secure.
    </p>
    <%= form_with url: verifications_send_otp_path, method: :post, local: true do |f| %>
      <div class="input-group">
        <%= f.text_field :phone, placeholder: "+91-", maxlength: 13, required: true, inputmode: "numeric", pattern: "[0-9+\-]*" %>
      </div>
      <%= f.submit "Send OTP", class: "btn" %>
    <% end %>
  </div>
  <div class="privacy-card">
    <h4>Your Privacy</h4>
    <p>
      We aim to keep the data you share during this process private, safe and secure. Learn more in our
      <a href="#">Privacy Policy</a>
    </p>
    <p>
      <a href="#">How Background Verification Works?</a>
    </p>
  </div>
  <div class="footer">
    <div class="brand">Truebg</div>
    <small>Copyright © 2025 Truebg. All Rights Reserved.</small>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const phoneInput = document.querySelector('input[name="phone"]');
      
      // Only allow numbers, plus signs, and hyphens
      phoneInput.addEventListener('keypress', function(e) {
        const charCode = e.which ? e.which : e.keyCode;
        const char = String.fromCharCode(charCode);
        
        // Allow: numbers (0-9), plus sign (+), hyphen (-), backspace, delete, tab, escape, enter
        if (charCode === 8 || charCode === 9 || charCode === 27 || charCode === 13 || charCode === 46) {
          return true;
        }
        
        // Allow only numbers, plus, and hyphen
        if (!/[0-9+\-]/.test(char)) {
          e.preventDefault();
          return false;
        }
      });
      
      // Prevent paste of non-allowed characters
      phoneInput.addEventListener('paste', function(e) {
        e.preventDefault();
        const pastedText = (e.clipboardData || window.clipboardData).getData('text');
        const allowedText = pastedText.replace(/[^0-9+\-]/g, '');
        this.value = allowedText;
      });
      
      // Remove any non-allowed characters on input
      phoneInput.addEventListener('input', function(e) {
        this.value = this.value.replace(/[^0-9+\-]/g, '');
      });
    });
  </script>
</body>
</html>
