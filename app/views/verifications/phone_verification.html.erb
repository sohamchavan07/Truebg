<div class="max-w-md mx-auto py-12 px-4 animate-fade-in">
  <!-- Header -->
  <div class="mb-12 text-center">
    <div class="inline-flex items-center justify-center p-4 bg-white rounded-3xl shadow-xl shadow-indigo-100 border border-indigo-50 mb-6 group transition-transform hover:scale-110 duration-500">
      <svg class="w-10 h-10 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
    </div>
    <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-4">Verify Phone</h1>
    <p class="text-lg text-slate-500 max-w-sm mx-auto">We'll send you a secure one-time password to verify your mobile number.</p>
  </div>

  <div class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl shadow-indigo-100/50 border border-white overflow-hidden">
    <div class="p-10">
      <!-- Progressive Step Indicator -->
      <div class="flex items-center justify-center mb-10">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-black shadow-lg shadow-indigo-200 ring-4 ring-indigo-50">1</div>
          <div class="h-0.5 w-12 bg-slate-100 rounded-full"></div>
          <div class="w-10 h-10 rounded-full bg-slate-50 text-slate-300 flex items-center justify-center text-sm font-black border-2 border-slate-100">2</div>
        </div>
      </div>

      <%= form_with url: verifications_send_otp_path, method: :post, class: "space-y-8" do |f| %>
        <div class="space-y-2 group">
          <%= f.label :phone, "Mobile Number", class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
          <div class="relative">
            <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 font-black tracking-tight pr-4 border-r border-slate-200">+91</span>
            <%= f.text_field :phone, value: session[:phone], placeholder: "9876543210", class: "w-full pl-20 pr-5 py-5 bg-slate-50/50 border border-slate-100 rounded-[1.5rem] focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-xl font-bold tracking-widest text-slate-700", required: true, maxlength: 10, inputmode: "numeric", pattern: "[0-9]*" %>
          </div>
          <p class="text-[10px] text-slate-400 pl-1 font-medium uppercase tracking-wider">A 5-digit security code will be sent via SMS.</p>
        </div>

        <div class="pt-2">
          <%= f.submit "Send Verification OTP", class: "w-full py-5 px-6 text-white bg-indigo-600 hover:bg-indigo-700 font-bold rounded-2xl shadow-lg shadow-indigo-100 transition-all transform hover:-translate-y-0.5 active:translate-y-0 cursor-pointer flex items-center justify-center gap-2 group text-lg" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-10 flex items-center justify-center gap-3 text-slate-400 group">
    <div class="p-2 bg-slate-100 rounded-full group-hover:bg-indigo-50 group-hover:text-indigo-500 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
    </div>
    <span class="text-xs font-bold uppercase tracking-[0.15em]">End-to-end encrypted</span>
  </div>
</div>

<style>
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
</style>