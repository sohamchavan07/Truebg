<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Mobile Verification</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      background: #fff;
      font-family: 'Inter', Arial, sans-serif;
      margin: 0;
      padding: 0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: center;
    }
    .logo {
      margin-top: 40px;
      margin-bottom: 24px;
      display: flex;
      justify-content: center;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      padding: 32px 24px 32px 24px;
      max-width: 340px;
      width: 100%;
      margin: 0 auto;
      text-align: center;
    }
    .card h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #111;
    }
    .card h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.2rem;
      color: #222;
    }
    .card p {
      font-size: 0.98rem;
      color: #555;
      margin-bottom: 1.5rem;
      line-height: 1.4;
    }
    .input-group {
      margin-bottom: 1.2rem;
    }
    .input-group input {
      width: 100%;
      padding: 12px 14px;
      font-size: 1rem;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      outline: none;
      transition: border 0.2s;
    }
    .input-group input:focus {
      border-color: #111;
    }
    .btn {
      width: 100%;
      padding: 12px 0;
      background: #111;
      color: #fff;
      font-size: 1rem;
      font-weight: 600;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn:hover {
      background: #222;
    }
    .footer {
      margin-top: 48px;
      text-align: center;
      color: #888;
      font-size: 0.95rem;
    }
    .footer .brand {
      font-family: 'Pacifico', cursive;
      font-size: 1.2rem;
      color: #888;
      margin-bottom: 4px;
      display: block;
    }
    .footer small {
      display: block;
      margin-top: 2px;
      font-size: 0.85rem;
      color: #aaa;
    }
  </style>
</head>
<body>
  <div class="logo">
    <img src="https://dummyimage.com/180x40/cccccc/000000&text=Logoipsum" alt="Logoipsum" height="40">
  </div>
  <div class="card">
    <h2>Welcome!</h2>
    <h3>Lets get you verified</h3>
    <p>
      To begin, please verify your mobile number<br>
      This ensures your information remains secure.
    </p>
    <%= form_with url: verifications_send_otp_path, method: :post, local: true do |f| %>
      <div class="input-group">
        <%= f.text_field :phone, placeholder: "+91-", maxlength: 13, required: true %>
      </div>
      <%= f.submit "Send OTP", class: "btn" %>
    <% end %>
  </div>
  <div class="footer">
    <span class="brand">truebg</span>
    Copyright © 2025 Truebg<br>
    <small>A better company begins with a personalised employee experience.</small>
  </div>
</body>
</html>
