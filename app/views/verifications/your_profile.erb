<div class="max-w-5xl mx-auto py-12 px-4 animate-fade-in">
  <!-- Interactive Header -->
  <div class="mb-16 text-center">
    <div class="inline-flex items-center justify-center p-5 bg-white rounded-[2.5rem] shadow-2xl shadow-indigo-100/50 border border-indigo-50 mb-8 group hover:scale-105 transition-all duration-500">
      <svg class="w-12 h-12 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
    </div>
    <h1 class="text-5xl font-black text-slate-900 tracking-tight mb-4">Verification Dashboard</h1>
    <p class="text-lg text-slate-500 max-w-2xl mx-auto font-medium">Please provide your comprehensive work and education history to finalize your premium background check report.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
    
    <!-- Sophisticated Sidebar Tracker -->
    <div class="lg:col-span-4">
      <div class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl shadow-indigo-100/30 border border-white p-8 sticky top-32">
        <div class="flex items-center justify-between mb-10">
          <h3 class="text-xs font-black text-slate-400 uppercase tracking-[0.2em]">Live Tracking</h3>
          <div class="flex items-center gap-2 px-3 py-1 bg-indigo-50 rounded-full border border-indigo-100/50">
            <span class="flex h-2 w-2 rounded-full bg-indigo-500 animate-pulse"></span>
            <span class="text-[10px] font-black text-indigo-600 uppercase tracking-widest">Active Scan</span>
          </div>
        </div>
        
        <div class="space-y-10 relative">
          <!-- Timeline Line -->
          <div class="absolute left-4 top-2 bottom-2 w-0.5 bg-slate-100 rounded-full"></div>

          <!-- Step 1: Identity -->
          <div class="relative flex items-center gap-6 group">
            <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-xs font-black shadow-lg shadow-green-100 ring-4 ring-green-50 z-10 transition-transform group-hover:scale-110">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-black text-slate-900 group-hover:text-indigo-600 transition-colors">Identity Proof</span>
              <span class="text-[10px] text-green-600 font-black uppercase tracking-widest">Verified via DigiLocker</span>
            </div>
          </div>
          
          <!-- Step 2: Data Collection -->
          <div class="relative flex items-center gap-6 group">
            <div class="w-8 h-8 rounded-full bg-indigo-600 text-white flex items-center justify-center text-xs font-black shadow-lg shadow-indigo-100 ring-4 ring-indigo-50 z-10 animate-pulse-slow">
              2
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-black text-indigo-600 uppercase tracking-widest">Data Collection</span>
              <span class="text-[10px] text-indigo-400 font-black uppercase tracking-widest">Awaiting Submission</span>
            </div>
          </div>
          
          <!-- Step 3: Global Scraping -->
          <div class="relative flex items-center gap-6 group">
            <div class="w-8 h-8 rounded-full bg-slate-50 text-slate-300 flex items-center justify-center text-xs font-black border-2 border-slate-100 z-10">
              3
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-black text-slate-400 uppercase tracking-widest">Final Audit</span>
              <span class="text-[10px] text-slate-300 font-black uppercase tracking-widest">Locked Stage</span>
            </div>
          </div>
        </div>
        
        <div class="mt-12 pt-8 border-t border-slate-50">
          <div class="bg-indigo-50/50 rounded-3xl p-5 border border-indigo-100/50 group hover:bg-white hover:shadow-xl hover:shadow-indigo-50 transition-all duration-500">
            <div class="flex gap-4">
              <div class="shrink-0 w-8 h-8 rounded-xl bg-white border border-indigo-100 flex items-center justify-center text-indigo-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              </div>
              <p class="text-[11px] text-slate-600 leading-relaxed font-medium">Your data is secured with <span class="font-black text-slate-900 italic">AES-256 Defense Grade Encryption</span>. Authorization restricted to verified enterprise entities.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Main Content Area -->
    <div class="lg:col-span-8 space-y-8">
      
      <!-- Work Experience Section -->
      <section class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl shadow-slate-200/30 border border-white overflow-hidden transition-all duration-500 hover:shadow-indigo-100/50 group/section">
        <div class="px-10 py-8 border-b border-slate-50 flex items-center justify-between bg-gradient-to-r from-white to-slate-50/30">
          <div class="flex items-center gap-5">
            <div class="p-3.5 bg-indigo-50 rounded-2xl text-indigo-600 transition-transform group-hover/section:scale-110">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <h3 class="text-2xl font-black text-slate-900 tracking-tight">Work Experience</h3>
              <p class="text-xs font-bold text-slate-400 mt-0.5 uppercase tracking-widest">Professional Timeline</p>
            </div>
          </div>
          <button onclick="document.getElementById('work-modal').classList.remove('hidden')" class="px-6 py-3 bg-indigo-600 text-white hover:bg-slate-900 font-bold rounded-2xl text-sm flex items-center gap-2 shadow-lg shadow-indigo-100 transition-all transform hover:-translate-y-1 active:translate-y-0 group">
            <svg class="w-4 h-4 group-hover:rotate-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Add Experience
          </button>
        </div>
        
        <div class="p-10">
          <% if @work_histories.any? %>
            <div class="grid grid-cols-1 gap-6">
              <% @work_histories.each do |work| %>
                <div class="group relative flex items-center justify-between p-6 rounded-3xl border border-slate-100 bg-slate-50/30 hover:bg-white hover:border-indigo-100 hover:shadow-xl hover:shadow-indigo-50 transition-all duration-500">
                  <div class="flex items-center gap-6">
                    <div class="w-14 h-14 rounded-2xl bg-white border border-slate-100 flex items-center justify-center text-xl font-black text-slate-700 shadow-sm group-hover:bg-indigo-600 group-hover:text-white group-hover:border-indigo-600 transition-all duration-500">
                      <%= work.company_name[0].upcase %>
                    </div>
                    <div>
                      <p class="text-lg font-black text-slate-900 leading-none mb-2"><%= work.job_title %></p>
                      <div class="flex items-center gap-3">
                        <p class="text-sm font-bold text-slate-500"><%= work.company_name %></p>
                        <span class="w-1 h-1 rounded-full bg-slate-200"></span>
                        <p class="text-[11px] font-black text-indigo-500 uppercase tracking-widest">
                          <%= work.start_date.strftime("%b %Y") %> — <%= work.current_job ? 'Present' : work.end_date&.strftime("%b %Y") %>
                        </p>
                      </div>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 px-4 py-1.5 bg-slate-100 rounded-full border border-slate-200/50">
                    <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.1em]">Verification Pending</span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-16 bg-slate-50/50 rounded-[2rem] border-2 border-dashed border-slate-100">
              <div class="w-24 h-24 mx-auto bg-white rounded-full flex items-center justify-center mb-6 shadow-xl shadow-slate-200/50 border border-slate-50 group transition-transform hover:scale-110">
                <svg class="w-10 h-10 text-slate-200 group-hover:text-indigo-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <h4 class="text-lg font-black text-slate-900 mb-2">No work history detected</h4>
              <p class="text-sm text-slate-400 max-w-xs mx-auto font-medium mb-8">Establish your professional credibility by adding your past employment records.</p>
              <button onclick="document.getElementById('work-modal').classList.remove('hidden')" class="text-indigo-600 font-black text-xs uppercase tracking-widest hover:text-slate-900 flex items-center justify-center gap-2 mx-auto group">
                Add first entry 
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </button>
            </div>
          <% end %>
        </div>
      </section>      <!-- Education Section -->
      <section class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl shadow-slate-200/30 border border-white overflow-hidden transition-all duration-500 hover:shadow-purple-100/50 group/section">
        <div class="px-10 py-8 border-b border-slate-50 flex items-center justify-between bg-gradient-to-r from-white to-slate-50/30">
          <div class="flex items-center gap-5">
            <div class="p-3.5 bg-purple-50 rounded-2xl text-purple-600 transition-transform group-hover/section:scale-110">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 14l9-5-9-5-9 5 9 5z"></path><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
            </div>
            <div>
              <h3 class="text-2xl font-black text-slate-900 tracking-tight">Education</h3>
              <p class="text-xs font-bold text-slate-400 mt-0.5 uppercase tracking-widest">Academic Credentials</p>
            </div>
          </div>
          <button onclick="document.getElementById('edu-modal').classList.remove('hidden')" class="px-6 py-3 bg-purple-600 text-white hover:bg-slate-900 font-bold rounded-2xl text-sm flex items-center gap-2 shadow-lg shadow-purple-100 transition-all transform hover:-translate-y-1 active:translate-y-0 group">
            <svg class="w-4 h-4 group-hover:rotate-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Add Education
          </button>
        </div>

        <div class="p-10">
          <% if @education_histories.any? %>
            <div class="grid grid-cols-1 gap-6">
              <% @education_histories.each do |edu| %>
                <div class="group relative flex items-center justify-between p-6 rounded-3xl border border-slate-100 bg-slate-50/30 hover:bg-white hover:border-purple-100 hover:shadow-xl hover:shadow-purple-50 transition-all duration-500">
                  <div class="flex items-center gap-6">
                    <div class="w-14 h-14 rounded-2xl bg-white border border-slate-100 flex items-center justify-center text-xl font-black text-slate-700 shadow-sm group-hover:bg-purple-600 group-hover:text-white group-hover:border-purple-600 transition-all duration-500">
                      <%= edu.institution_name[0].upcase %>
                    </div>
                    <div>
                      <p class="text-lg font-black text-slate-900 leading-none mb-2"><%= edu.degree %> in <%= edu.field_of_study %></p>
                      <div class="flex items-center gap-3">
                        <p class="text-sm font-bold text-slate-500"><%= edu.institution_name %></p>
                        <span class="w-1 h-1 rounded-full bg-slate-200"></span>
                        <p class="text-[11px] font-black text-purple-500 uppercase tracking-widest leading-none">
                          Class of <%= edu.graduation_year %>
                        </p>
                      </div>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 px-4 py-1.5 bg-slate-100 rounded-full border border-slate-200/50">
                    <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.1em]">Awaiting Audit</span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-16 bg-slate-50/50 rounded-[2rem] border-2 border-dashed border-slate-100">
              <div class="w-24 h-24 mx-auto bg-white rounded-full flex items-center justify-center mb-6 shadow-xl shadow-slate-200/50 border border-slate-50 group transition-transform hover:scale-110">
                <svg class="w-10 h-10 text-slate-200 group-hover:text-purple-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
              </div>
              <h4 class="text-lg font-black text-slate-900 mb-2">No education found</h4>
              <p class="text-sm text-slate-400 max-w-xs mx-auto font-medium mb-8">Your academic achievements are a vital part of your verified professional identity.</p>
              <button onclick="document.getElementById('edu-modal').classList.remove('hidden')" class="text-purple-600 font-black text-xs uppercase tracking-widest hover:text-slate-900 flex items-center justify-center gap-2 mx-auto group">
                Add first degree
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </button>
            </div>
          <% end %>
        </div>
      </section>n>

      <!-- Enhanced Final Review -->
      <div class="bg-slate-900 rounded-[2.5rem] p-12 shadow-2xl relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/20 via-transparent to-purple-600/20 opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>
        <div class="relative z-10 flex flex-col lg:flex-row items-center justify-between gap-10">
          <div class="text-center lg:text-left">
            <h3 class="text-3xl font-black text-white mb-3">Ready to certify?</h3>
            <p class="text-slate-400 text-sm max-w-sm font-medium leading-relaxed">System-generated audit will initiate once you submit. Double check all entries for accuracy to ensure no delays.</p>
          </div>
          <%= button_to verifications_submit_verification_path, method: :post, class: "shrink-0 relative group/btn inline-flex items-center justify-center px-10 py-5 font-black text-white bg-indigo-600 rounded-[1.5rem] overflow-hidden transition-all hover:scale-105 active:scale-95 shadow-[0_20px_50px_-15px_rgba(79,70,229,0.5)] border border-indigo-400/30" do %>
            <span class="relative flex items-center gap-3">
              Certify & Submit Profile
              <svg class="w-6 h-6 group-hover/btn:translate-x-1.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Premium Glassmorphic Modals -->
<div id="work-modal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[100] flex items-center justify-center p-4">
  <div class="bg-white rounded-[2.5rem] p-10 max-w-lg w-full shadow-2xl border border-white relative animate-slide-up">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h3 class="text-2xl font-black text-slate-900 leading-none">Add Experience</h3>
        <p class="text-xs font-bold text-slate-400 mt-2 uppercase tracking-widest">Professional History</p>
      </div>
      <button onclick="document.getElementById('work-modal').classList.add('hidden')" class="p-3 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-2xl transition-all">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    <%= form_with model: WorkHistory.new, url: verifications_add_work_history_path, class: "space-y-6" do |f| %>
      <div class="space-y-2 group">
        <%= f.label :company_name, class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
        <%= f.text_field :company_name, class: "w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-900 font-bold", placeholder: "e.g. Acme Corp", required: true %>
      </div>
      <div class="space-y-2 group">
        <%= f.label :job_title, class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
        <%= f.text_field :job_title, class: "w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-900 font-bold", placeholder: "e.g. Senior Product Manager", required: true %>
      </div>
      <div class="grid grid-cols-2 gap-6">
        <div class="space-y-2 group">
          <%= f.label :start_date, class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
          <%= f.date_field :start_date, class: "w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-900 font-bold", required: true %>
        </div>
        <div class="space-y-2 group">
          <%= f.label :end_date, "End date", class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
          <%= f.date_field :end_date, class: "w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-900 font-bold" %>
        </div>
      </div>
      <div class="space-y-2 group">
        <%= f.label :location, class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
        <%= f.text_field :location, class: "w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-900 font-bold", placeholder: "City, Country", required: true %>
      </div>
      <div class="flex gap-4 pt-6">
        <%= f.submit "Save Experience", class: "w-full py-5 px-6 text-white bg-indigo-600 hover:bg-slate-900 font-black rounded-2xl shadow-xl shadow-indigo-100 transition-all transform hover:-translate-y-1 active:translate-y-0 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

<div id="edu-modal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[100] flex items-center justify-center p-4">
  <div class="bg-white rounded-[2.5rem] p-10 max-w-lg w-full shadow-2xl border border-white relative animate-slide-up">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h3 class="text-2xl font-black text-slate-900 leading-none">Add Education</h3>
        <p class="text-xs font-bold text-slate-400 mt-2 uppercase tracking-widest">Academic Background</p>
      </div>
      <button onclick="document.getElementById('edu-modal').classList.add('hidden')" class="p-3 text-slate-400 hover:text-purple-600 hover:bg-purple-50 rounded-2xl transition-all">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    <%= form_with model: EducationHistory.new, url: verifications_add_education_history_path, class: "space-y-6" do |f| %>
      <div class="space-y-2 group">
        <%= f.label :institution_name, "University / College", class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-purple-500 transition-colors" %>
        <%= f.text_field :institution_name, class: "w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all text-slate-900 font-bold", placeholder: "e.g. Stanford University", required: true %>
      </div>
      <div class="grid grid-cols-2 gap-6">
        <div class="space-y-2 group">
          <%= f.label :degree, class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-purple-500 transition-colors" %>
          <%= f.text_field :degree, class: "w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all text-slate-900 font-bold", placeholder: "B.Tech, MBA...", required: true %>
        </div>
        <div class="space-y-2 group">
          <%= f.label :graduation_year, "Graduation Year", class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-purple-500 transition-colors" %>
          <%= f.text_field :graduation_year, class: "w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all text-slate-900 font-bold", placeholder: "2024", required: true %>
        </div>
      </div>
      <div class="space-y-2 group">
        <%= f.label :field_of_study, "Field of Study", class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-purple-500 transition-colors" %>
        <%= f.text_field :field_of_study, class: "w-full px-5 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 transition-all text-slate-900 font-bold", placeholder: "e.g. Computer Science", required: true %>
      </div>
      <div class="flex gap-4 pt-6">
        <%= f.submit "Save Education", class: "w-full py-5 px-6 text-white bg-purple-600 hover:bg-slate-900 font-black rounded-2xl shadow-xl shadow-purple-100 transition-all transform hover:-translate-y-1 active:translate-y-0 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

<style>
@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-slide-up {
  animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.animate-pulse-slow {
  animation: pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: .8; transform: scale(1.05); }
}
</style>