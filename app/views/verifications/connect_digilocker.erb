<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verification Page</title>
  <style>
    body {
      margin: 0;
      font-family: system-ui, sans-serif;
      background: linear-gradient(to bottom, #eef0f8, #ffffff);
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }
    .card {
      background: white;
      border-radius: 12px;
      width: 360px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      padding: 24px;
      box-sizing: border-box;
      text-align: center;
    }
    .logo {
      height: 32px;
      margin-bottom: 20px;
    }
    .alert {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      color: #15803d;
      font-size: 14px;
      border-radius: 8px;
      padding: 8px 12px;
      display: inline-block;
      text-align: left;
      margin-bottom: 20px;
    }
    .title {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .desc {
      font-size: 14px;
      color: #555;
      margin-bottom: 20px;
    }
    .list-item {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 12px 0;
      border-top: 1px solid #eee;
      cursor: pointer;
    }
    .list-item:first-of-type {
      border-top: none;
    }
    .list-text {
      text-align: left;
    }
    .list-title {
      font-size: 14px;
      font-weight: 500;
    }
    .list-sub {
      font-size: 12px;
      color: #666;
    }
    .arrow {
      color: #999;
      font-size: 16px;
    }
    .btn {
      width: 100%;
      background: #e5e7eb;
      color: #6b7280;
      font-weight: 500;
      padding: 12px;
      border: none;
      border-radius: 8px;
      margin-top: 20px;
      cursor: not-allowed;
    }
    .link {
      font-size: 13px;
      color: #555;
      margin-top: 12px;
      cursor: pointer;
    }
    .link:hover {
      text-decoration: underline;
    }
    .footer {
      font-size: 11px;
      color: #999;
      margin-top: 24px;
    }
  </style>
</head>
<body>

  <div class="card">
    <!-- Logo -->

    <!-- OTP Verified -->
    <div class="alert">OTP verified.</div>

    <!-- Title & Description -->
    <div class="title">The Express Path to Verification</div>
    <div class="desc">
      Save time by letting us pre-fill your details. Simply upload your latest résumé and connect to DigiLocker.
      We'll do the heavy lifting.
    </div>

    <!-- Upload Resume -->
    <div class="list-item">
      <div class="list-text">
        <div class="list-title">Upload Your Résumé</div>
        <div class="list-sub">We'll parse your work and education history automatically</div>
      </div>
      <div class="arrow">&#8250;</div>
    </div>

    <!-- DigiLocker -->
    <div class="list-item">
      <div class="list-text">
        <div class="list-title">Connect with DigiLocker</div>
        <div class="list-sub">Securely fetch your verified ID and Address proofs.</div>
      </div>
      <div class="arrow">&#8250;</div>
    </div>

    <!-- Button -->
    <button class="btn" disabled>Review Your Details</button>

    <!-- Link -->
    <div class="link">Nevermind, I'll Enter Manually</div>

    <!-- Footer -->
    <div class="footer">Copyright © 2025 Truebg. All Rights Reserved.</div>
  </div>

</body>
</html>
