<div class="max-w-md mx-auto">
  <!-- Header -->
  <div class="mb-10 text-center">
    <div class="inline-flex items-center justify-center p-3 bg-indigo-50 rounded-2xl mb-4 shadow-sm border border-indigo-100">
      <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
    </div>
    <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight mb-3">Identity Proof</h1>
    <p class="text-lg text-gray-500 max-w-sm mx-auto">Connect your DigiLocker to fetch verified identity documents instantly.</p>
  </div>

  <div class="bg-white rounded-[2rem] shadow-xl shadow-gray-200/50 border border-gray-100 overflow-hidden">
    <div class="p-10">
      <div class="flex items-center justify-center mb-8">
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-sm font-bold shadow-sm">✓</div>
          <div class="h-0.5 w-12 bg-green-500"></div>
          <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-sm font-bold shadow-sm">✓</div>
          <div class="h-0.5 w-12 bg-indigo-500"></div>
          <div class="w-8 h-8 rounded-full bg-indigo-500 text-white flex items-center justify-center text-sm font-bold shadow-sm">2</div>
          <div class="h-0.5 w-12 bg-gray-100"></div>
          <div class="w-8 h-8 rounded-full bg-gray-100 text-gray-400 flex items-center justify-center text-sm font-bold">3</div>
        </div>
      </div>

      <div class="bg-gray-50/50 rounded-2xl p-6 mb-8 border border-gray-100">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6">Automated Check List</h3>
        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="shrink-0 p-1.5 bg-green-100 rounded-lg text-green-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900 leading-tight">Aadhaar Verification</p>
              <p class="text-xs text-gray-500 mt-0.5">Real-time authenticity validation</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="shrink-0 p-1.5 bg-green-100 rounded-lg text-green-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900 leading-tight">PAN Data Extraction</p>
              <p class="text-xs text-gray-500 mt-0.5">Secure tax record fetching</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="shrink-0 p-1.5 bg-indigo-100 rounded-lg text-indigo-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900 leading-tight">Instant Decisioning</p>
              <p class="text-xs text-gray-500 mt-0.5">Machine-driven score generation</p>
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-4">
        <%= link_to verifications_primary_details_path, class: "w-full py-4 px-6 text-white bg-indigo-600 hover:bg-indigo-700 font-bold rounded-2xl shadow-lg shadow-indigo-100 transition-all transform hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-2 group" do %>
          Connect DigiLocker
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        <% end %>
        <p class="text-center text-[10px] text-gray-400 px-6 uppercase tracking-wider font-medium">
          Powered by Gov-Auth API &bull; 256-bit Encrypted
        </p>
      </div>
    </div>
  </div>
</div>
