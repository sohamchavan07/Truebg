<div class="max-w-5xl mx-auto py-12 px-4 animate-fade-in">
  <!-- Interactive Header -->
  <div class="mb-16 text-center">
    <div class="inline-flex items-center justify-center p-5 bg-white rounded-[2.5rem] shadow-2xl shadow-indigo-100/50 border border-indigo-50 mb-8 group hover:scale-105 transition-all duration-500">
      <svg class="w-12 h-12 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
    </div>
    <h1 class="text-5xl font-black text-slate-900 tracking-tight mb-4">Final Review</h1>
    <p class="text-lg text-slate-500 max-w-2xl mx-auto font-medium">Please review all your details before certifying and submitting your profile for verification.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
    <!-- Sidebar -->
    <div class="lg:col-span-4">
      <div class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl shadow-indigo-100/30 border border-white p-8 sticky top-32">
        <div class="space-y-10 relative">
          <div class="absolute left-4 top-2 bottom-2 w-0.5 bg-slate-100 rounded-full"></div>
          <div class="relative flex items-center gap-6 group">
            <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-xs font-black shadow-lg shadow-green-100 ring-4 ring-green-50 z-10">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-black text-slate-900">Identity</span>
            </div>
          </div>
          <div class="relative flex items-center gap-6 group">
            <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-xs font-black shadow-lg shadow-green-100 ring-4 ring-green-50 z-10">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-black text-slate-900">Work History</span>
            </div>
          </div>
          <div class="relative flex items-center gap-6 group">
            <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-xs font-black shadow-lg shadow-green-100 ring-4 ring-green-50 z-10">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-black text-slate-900">Education</span>
            </div>
          </div>
          <div class="relative flex items-center gap-6 group">
            <div class="w-8 h-8 rounded-full bg-indigo-600 text-white flex items-center justify-center text-xs font-black shadow-lg shadow-indigo-100 ring-4 ring-indigo-50 z-10 animate-pulse-slow">
              4
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-black text-indigo-600 uppercase tracking-widest">Final Audit</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="lg:col-span-8 space-y-8">
      <section class="bg-white rounded-[2.5rem] p-10 border border-slate-100">
        <h3 class="text-2xl font-black text-slate-900 mb-8">Profile Summary</h3>
        
        <div class="space-y-10">
          <div>
            <div class="flex items-center justify-between mb-4">
              <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest">Work History</h4>
              <% unless @verification_case&.status == 'completed' %>
                <%= link_to "Edit", verifications_work_experience_path, class: "text-xs font-bold text-indigo-600" %>
              <% end %>
            </div>
            <div class="space-y-4">
              <% @work_histories.each do |work| %>
                <div class="p-4 rounded-2xl bg-slate-50 border border-slate-100 flex justify-between items-center">
                  <div>
                    <p class="font-black text-slate-900"><%= work.job_title %></p>
                    <p class="text-xs text-slate-500"><%= work.company_name %></p>
                  </div>
                  <p class="text-[10px] font-bold text-slate-400"><%= work.start_date.year %> - <%= work.current_job ? 'Present' : work.end_date&.year %></p>
                </div>
              <% end %>
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between mb-4">
              <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest">Education History</h4>
              <% unless @verification_case&.status == 'completed' %>
                <%= link_to "Edit", verifications_academic_history_path, class: "text-xs font-bold text-indigo-600" %>
              <% end %>
            </div>
            <div class="space-y-4">
              <% @education_histories.each do |edu| %>
                <div class="p-4 rounded-2xl bg-slate-50 border border-slate-100 flex justify-between items-center">
                  <div>
                    <p class="font-black text-slate-900"><%= edu.degree %></p>
                    <p class="text-xs text-slate-500"><%= edu.institution_name %></p>
                  </div>
                  <p class="text-[10px] font-bold text-slate-400">Class of <%= edu.graduation_year %></p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <!-- Final Action Card -->
      <div class="bg-slate-900 rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden group">
        <% if @verification_case&.status == 'completed' %>
          <div class="relative z-10 text-center py-4">
             <div class="inline-flex items-center gap-3 px-6 py-3 bg-green-500/10 border border-green-500/20 rounded-2xl mb-4">
               <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
               <span class="text-sm font-black text-green-500 uppercase tracking-widest">Profile Locked & Submitted</span>
             </div>
             <p class="text-slate-400 text-xs font-medium">This profile is currently under audit and cannot be modified.</p>
          </div>
        <% else %>
          <%= form_with url: verifications_submit_verification_path, method: :post, local: true, data: { turbo: false } do |f| %>
            <div class="relative z-10">
              <div class="flex items-center gap-4 mb-6 p-4 bg-white/5 rounded-2xl border border-white/10">
                <input type="checkbox" id="certify" class="w-5 h-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" required>
                <label for="certify" class="text-xs font-medium text-slate-300">I certify that all information provided is accurate and I consent to the background verification process.</label>
              </div>
              
              <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
                <div class="text-center sm:text-left">
                  <h3 class="text-xl font-black text-white mb-1">Ready to submit?</h3>
                  <p class="text-slate-400 text-[10px] uppercase tracking-widest font-bold">Manual audit will begin immediately</p>
                </div>
                <button type="submit" class="w-full sm:w-auto px-10 py-4 font-black text-white bg-indigo-600 rounded-2xl hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-500/20 active:scale-95">
                  Certify & Submit Profile
                </button>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
.animate-pulse-slow { animation: pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
@keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: .8; transform: scale(1.05); } }
</style>
