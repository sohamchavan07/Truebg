<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Identity and Address Verification</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Pacifico&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f4f4;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 24px;
            font-weight: 600;
            color: #333;
            margin-bottom: 20px;
        }

        .logo-icon {
            width: 24px;
            height: 24px;
            background: linear-gradient(45deg, #7a5af8, #6b46c1);
            border-radius: 4px;
            position: relative;
        }

        .logo-icon::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 12px;
            height: 12px;
            background: white;
            border-radius: 2px;
        }

        .main-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            padding: 40px;
            max-width: 600px;
            width: 100%;
            margin-bottom: 30px;
        }

        .progress-container {
            margin-bottom: 30px;
        }

        .step-indicator {
            font-size: 14px;
            font-weight: 500;
            color: #666;
            margin-bottom: 12px;
        }

        .progress-bar {
            width: 100%;
            height: 4px;
            background-color: #e5e7eb;
            border-radius: 2px;
            overflow: hidden;
        }

        .progress-fill {
            width: 50%;
            height: 100%;
            background-color: #7a5af8;
            border-radius: 2px;
            transition: width 0.3s ease;
        }

        .title {
            font-size: 28px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 8px;
            text-align: left;
        }

        .description {
            font-size: 16px;
            color: #6b7280;
            margin-bottom: 32px;
            text-align: left;
            line-height: 1.5;
        }

        .info-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .info-item {
            display: flex;
            align-items: center;
            padding: 16px;
            background-color: #f9fafb;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
        }

        .info-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 16px;
            font-size: 18px;
            background-color: #f3f4f6;
            color: #6b7280;
        }

        .info-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .info-label {
            font-size: 14px;
            font-weight: 500;
            color: #6b7280;
        }

        .info-value {
            font-size: 16px;
            font-weight: 600;
            color: #1f2937;
            word-break: break-word;
        }

        .info-status {
            margin-left: 12px;
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }

        .status-verified {
            background-color: #dcfce7;
            color: #16a34a;
        }

        .status-pending {
            background-color: #f3f4f6;
            color: #9ca3af;
        }

        .next-button {
            background: linear-gradient(135deg, #7a5af8, #6b46c1);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 16px 24px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            margin-top: 32px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(122, 90, 248, 0.3);
        }

        .next-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(122, 90, 248, 0.4);
        }

        .footer {
            text-align: center;
        }

        .footer-logo {
            font-family: 'Pacifico', cursive;
            font-size: 24px;
            color: #7a5af8;
            margin-bottom: 8px;
        }

        .copyright {
            font-size: 14px;
            color: #9ca3af;
        }

        @media (max-width: 640px) {
            .main-card {
                padding: 24px;
                margin: 0 16px;
            }

            .title {
                font-size: 24px;
            }

            .info-item {
                padding: 12px;
            }

            .info-icon {
                width: 32px;
                height: 32px;
                font-size: 16px;
                margin-right: 12px;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">
            <div class="logo-icon"></div>
            Logoipsum
        </div>
    </div>

    <div class="main-card">
        <div class="progress-container">
            <div class="step-indicator">STEP 1 OF 2</div>
            <div class="progress-bar">
                <div class="progress-fill"></div>
            </div>
        </div>

        <h1 class="title">Your Identity and Address</h1>
        <p class="description">The following information was securely fetched from your DigiLocker account.</p>

        <div class="info-list">
            <div class="info-item">
                <div class="info-icon">👤</div>
                <div class="info-content">
                    <div class="info-label">Full Name</div>
                    <div class="info-value">Priya Ashok Pathak</div>
                </div>
                <div class="info-status status-pending">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 2v6h-6M3 12a9 9 0 0 1 15-6.7L21 8M3 22v-6h6M21 12a9 9 0 0 1-15 6.7L3 16"/>
                    </svg>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">📅</div>
                <div class="info-content">
                    <div class="info-label">Date of Birth</div>
                    <div class="info-value">10/02/1990</div>
                </div>
                <div class="info-status status-verified">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20,6 9,17 4,12"></polyline>
                    </svg>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">🪪</div>
                <div class="info-content">
                    <div class="info-label">PAN Number</div>
                    <div class="info-value">XXXX-XXXX-1234</div>
                </div>
                <div class="info-status status-pending">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 2v6h-6M3 12a9 9 0 0 1 15-6.7L21 8M3 22v-6h6M21 12a9 9 0 0 1-15 6.7L3 16"/>
                    </svg>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">🛡️</div>
                <div class="info-content">
                    <div class="info-label">Aadhaar Number</div>
                    <div class="info-value">XXXX-XXXX-1234</div>
                </div>
                <div class="info-status status-pending">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 2v6h-6M3 12a9 9 0 0 1 15-6.7L21 8M3 22v-6h6M21 12a9 9 0 0 1-15 6.7L3 16"/>
                    </svg>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">🏠</div>
                <div class="info-content">
                    <div class="info-label">Present Address</div>
                    <div class="info-value">Indu Dreams, Flat 106/108, Rajarampuri 3rd Lane, Kolhapur, Maharashtra 416001</div>
                </div>
                <div class="info-status status-pending">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 2v6h-6M3 12a9 9 0 0 1 15-6.7L21 8M3 22v-6h6M21 12a9 9 0 0 1-15 6.7L3 16"/>
                    </svg>
                </div>
            </div>
        </div>

     <%= link_to "Next: Your Work Profile", verifications_your_profile_path, class: "next-button" %>
    </div>

    <div class="footer">
        <div class="footer-logo">truebg</div>
        <div class="copyright">Copyright © 2025 Truebg. All Rights Reserved.</div>
    </div>
</body>
</html>