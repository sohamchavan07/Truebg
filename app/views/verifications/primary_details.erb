<div class="max-w-2xl mx-auto">
  <!-- Header -->
  <div class="mb-10 text-center">
    <div class="inline-flex items-center justify-center p-3 bg-indigo-50 rounded-2xl mb-4 shadow-sm border border-indigo-100">
      <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
    </div>
    <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight mb-3">Primary Details</h1>
    <p class="text-lg text-gray-500 max-w-lg mx-auto">Please provide your personal information to establish your identity in our verification system.</p>
  </div>

  <div class="bg-white rounded-[2rem] shadow-xl shadow-gray-200/50 border border-gray-100 overflow-hidden">
    <div class="p-10">
      <div class="flex items-center justify-center mb-8">
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 rounded-full bg-indigo-500 text-white flex items-center justify-center text-sm font-bold shadow-sm">1</div>
          <div class="h-0.5 w-12 bg-indigo-100"></div>
          <div class="w-8 h-8 rounded-full bg-gray-100 text-gray-400 flex items-center justify-center text-sm font-bold">2</div>
        </div>
      </div>

      <%= form_with model: @candidate, url: verifications_update_primary_details_path, method: :patch, class: "space-y-6" do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <%= f.label :first_name, class: "text-sm font-semibold text-gray-700" %>
            <%= f.text_field :first_name, class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all", placeholder: "e.g. John", required: true %>
          </div>
          <div class="space-y-2">
            <%= f.label :last_name, class: "text-sm font-semibold text-gray-700" %>
            <%= f.text_field :last_name, class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all", placeholder: "e.g. Doe", required: true %>
          </div>
        </div>

        <div class="space-y-2">
          <%= f.label :dob, "Date of Birth", class: "text-sm font-semibold text-gray-700" %>
          <%= f.date_field :dob, class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all", required: true %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <%= f.label :pan_number, "PAN Number", class: "text-sm font-semibold text-gray-700" %>
            <%= f.text_field :pan_number, class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all uppercase", placeholder: "ABCDE1234F", required: true, maxlength: 10 %>
          </div>
          <div class="space-y-2">
            <%= f.label :aadhaar_number, "Aadhaar Number", class: "text-sm font-semibold text-gray-700" %>
            <%= f.text_field :aadhaar_number, class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all", placeholder: "0000 0000 0000", required: true, maxlength: 12 %>
          </div>
        </div>

        <div class="space-y-2">
          <%= f.label :address, class: "text-sm font-semibold text-gray-700" %>
          <%= f.text_area :address, class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all", rows: 3, placeholder: "123, Street Name...", required: true %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <%= f.label :city, class: "text-sm font-semibold text-gray-700" %>
            <%= f.text_field :city, class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all", placeholder: "City", required: true %>
          </div>
          <div class="space-y-2">
            <%= f.label :state, class: "text-sm font-semibold text-gray-700" %>
            <%= f.text_field :state, class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all", placeholder: "State", required: true %>
          </div>
          <div class="space-y-2">
            <%= f.label :pincode, class: "text-sm font-semibold text-gray-700" %>
            <%= f.text_field :pincode, class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all", placeholder: "110001", required: true, maxlength: 6 %>
          </div>
        </div>

        <div class="pt-6">
          <%= f.submit "Save & Continue", class: "w-full py-4 px-6 text-white bg-indigo-600 hover:bg-indigo-700 font-bold rounded-2xl shadow-lg shadow-indigo-100 transition-all transform hover:-translate-y-0.5 active:translate-y-0 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
  
  <p class="text-center text-sm text-gray-400 mt-8">
    All information is encrypted and processed according to our <a href="#" class="text-indigo-600 font-medium">Privacy Policy</a>.
  </p>
</div>