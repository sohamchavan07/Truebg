<div class="max-w-2xl mx-auto py-12 px-4 animate-fade-in">
  <!-- Header -->
  <div class="mb-12 text-center">
    <div class="inline-flex items-center justify-center p-4 bg-white rounded-3xl shadow-xl shadow-indigo-100 border border-indigo-50 mb-6 group transition-transform hover:scale-110 duration-500">
      <svg class="w-10 h-10 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
    </div>
    <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-4">Primary Details</h1>
    <p class="text-lg text-slate-500 max-w-lg mx-auto">Establish your identity in our secure verification system with your personal information.</p>
  </div>

  <div class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl shadow-indigo-100/50 border border-white overflow-hidden overflow-visible">
    <div class="p-10">
      <!-- Progressive Step Indicator -->
      <div class="flex items-center justify-center mb-12">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-green-500 text-white flex items-center justify-center text-sm font-black shadow-lg shadow-green-100 ring-4 ring-green-50">✓</div>
          <div class="h-0.5 w-12 bg-green-200 rounded-full"></div>
          <div class="w-10 h-10 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-black shadow-lg shadow-indigo-200 ring-4 ring-indigo-50 leading-none">2</div>
          <div class="h-0.5 w-12 bg-slate-100 rounded-full"></div>
          <div class="w-10 h-10 rounded-full bg-slate-50 text-slate-300 flex items-center justify-center text-sm font-black border-2 border-slate-100">3</div>
        </div>
      </div>

      <%= form_with model: @candidate, url: verifications_update_primary_details_path, method: :patch, class: "space-y-8", data: { turbo: false } do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-2 group">
            <%= f.label :first_name, class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
            <%= f.text_field :first_name, class: "w-full px-5 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-700 font-medium", placeholder: "e.g. John", required: true %>
          </div>
          <div class="space-y-2 group">
            <%= f.label :last_name, class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
            <%= f.text_field :last_name, class: "w-full px-5 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-700 font-medium", placeholder: "e.g. Doe", required: true %>
          </div>
        </div>

        <div class="space-y-2 group">
          <%= f.label :dob, "Date of Birth", class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
          <%= f.date_field :dob, class: "w-full px-5 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-700 font-medium", required: true %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-2 group">
            <%= f.label :pan_number, "PAN Number", class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
            <%= f.text_field :pan_number, class: "w-full px-5 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-700 font-medium uppercase tracking-widest", placeholder: "ABCDE1234F", required: true, maxlength: 10 %>
          </div>
          <div class="space-y-2 group">
            <%= f.label :aadhaar_number, "Aadhaar Number", class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
            <%= f.text_field :aadhaar_number, class: "w-full px-5 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-700 font-medium", placeholder: "0000 0000 0000", required: true, maxlength: 12 %>
          </div>
        </div>

        <div class="space-y-2 group">
          <%= f.label :address, class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
          <%= f.text_area :address, class: "w-full px-5 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-700 font-medium", rows: 3, placeholder: "123, Street Name...", required: true %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2 group">
            <%= f.label :city, class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
            <%= f.text_field :city, class: "w-full px-5 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-700 font-medium", placeholder: "City", required: true %>
          </div>
          <div class="space-y-2 group">
            <%= f.label :state, class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
            <%= f.text_field :state, class: "w-full px-5 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-700 font-medium", placeholder: "State", required: true %>
          </div>
          <div class="space-y-2 group">
            <%= f.label :pincode, class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 group-focus-within:text-indigo-500 transition-colors" %>
            <%= f.text_field :pincode, class: "w-full px-5 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-700 font-medium", placeholder: "110001", required: true, maxlength: 6 %>
          </div>
        </div>

        <div class="pt-6">
          <%= f.submit "Save & Continue", class: "w-full py-4 px-6 text-white bg-indigo-600 hover:bg-indigo-700 font-bold rounded-2xl shadow-lg shadow-indigo-100 transition-all transform hover:-translate-y-0.5 active:translate-y-0 cursor-pointer flex items-center justify-center gap-2 group" %>
        </div>
      <% end %>
    </div>
  </div>
  
  <p class="text-center text-xs text-slate-400 mt-10">
    All information is encrypted and processed according to our <a href="#" class="text-indigo-600 font-bold hover:underline">Privacy Policy</a>.
  </p>
</div>

<style>
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
</style>