<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Truebg – Secure Background Verifications</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #0d9488;
      --primary-light: #14b8a6;
      --glass: rgba(255, 255, 255, 0.7);
      --glass-border: rgba(255, 255, 255, 0.3);
    }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      overflow-x: hidden;
    }
    .glass {
      background: var(--glass);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--glass-border);
    }
    .text-gradient {
      background: linear-gradient(135deg, #0d9488, #14b8a6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .bg-gradient-premium {
      background: linear-gradient(135deg, #ecfeff 0%, #cffafe 50%, #ffffff 100%);
    }
    .hover-scale {
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .hover-scale:hover {
      transform: scale(1.05);
    }
    .hover-lift {
      transition: all 0.3s ease;
    }
    .hover-lift:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    }
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .marquee-content {
      display: flex;
      width: max-content;
      animation: marquee 30s linear infinite;
    }
    .marquee-content:hover {
      animation-play-state: paused;
    }
    .nav-active {
      color: var(--primary);
    }
    .shadow-premium {
      box-shadow: 0 10px 30px -10px rgba(13, 148, 136, 0.3);
    }
  </style>
</head>
<body class="bg-white text-slate-900 antialiased">
  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-[100] transition-all duration-300" id="navbar">
    <div class="max-w-7xl mx-auto px-6 py-4">
      <div class="glass rounded-2xl px-6 py-3 flex items-center justify-between shadow-sm">
        <div class="flex items-center space-x-8">
          <a href="#" class="flex items-center space-x-2 group">
            <div class="w-10 h-10 bg-teal-600 rounded-xl flex items-center justify-center text-white shadow-premium group-hover:rotate-12 transition-transform">
              <i data-lucide="shield-check" class="w-6 h-6"></i>
            </div>
            <span class="text-2xl font-extrabold tracking-tight text-slate-900">Truebg</span>
          </a>
          <div class="hidden md:flex items-center space-x-6 text-sm font-semibold text-slate-600">
            <a href="#features" class="hover:text-teal-600 transition-colors">Features</a>
            <a href="#process" class="hover:text-teal-600 transition-colors">Process</a>
            <a href="#stats" class="hover:text-teal-600 transition-colors">Integrations</a>
          </div>
        </div>

        <div class="flex items-center space-x-4">
          <% if candidate_signed_in? %>
            <a href="/candidates/dashboard" class="hidden sm:flex items-center space-x-2 px-5 py-2.5 rounded-xl bg-slate-900 text-white font-bold hover:bg-teal-600 transition-all shadow-premium">
              <span>Dashboard</span>
              <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </a>
            <button onclick="logout()" class="p-2.5 rounded-xl border border-slate-200 hover:bg-slate-50 transition-colors text-slate-600">
              <i data-lucide="log-out" class="w-5 h-5"></i>
            </button>
          <% else %>
            <a href="/candidates/sign_up" class="px-6 py-2.5 rounded-xl bg-slate-900 text-white font-bold hover:bg-teal-600 transition-all shadow-lg hover:shadow-teal-200/50">
              Get Started
            </a>
          <% end %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-gradient-premium">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none opacity-20">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-teal-300 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-300 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="flex flex-col lg:flex-row items-center gap-16">
        <div class="lg:w-1/2 text-center lg:text-left">
          <div class="inline-flex items-center space-x-2 px-4 py-2 rounded-full bg-teal-50 border border-teal-100 text-teal-700 text-xs font-bold uppercase tracking-wider mb-8 animate-fade-in">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
            </span>
            <span>Next-Gen Verification Platform</span>
          </div>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-slate-900 leading-[1.1] mb-8 tracking-tight">
            Trust built on <span class="text-gradient">Certainty</span>
          </h1>
          <p class="text-lg md:text-xl text-slate-600 mb-10 leading-relaxed max-w-xl">
            Streamline your hiring with AI-powered candidate verification. Secure, compliant, and lightning fast.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a href="/candidates/sign_up" class="group px-8 py-4 rounded-2xl bg-teal-600 text-white font-bold text-lg hover:bg-teal-700 transition-all shadow-premium flex items-center space-x-3">
              <span>Start Verification</span>
              <i data-lucide="chevron-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform"></i>
            </a>
            <a href="#process" class="px-8 py-4 rounded-2xl border-2 border-teal-100 text-teal-700 font-bold text-lg hover:bg-teal-50 transition-all">
              Watch Demo
            </a>
          </div>
          <div class="mt-12 flex items-center justify-center lg:justify-start space-x-6 text-slate-400">
            <div class="flex -space-x-3">
              <% [1,2,3,4].each do |i| %>
                <div class="w-10 h-10 rounded-full border-2 border-white bg-slate-100 flex items-center justify-center overflow-hidden">
                  <img src="https://i.pravatar.cc/40?img=<%= i + 10 %>" alt="User">
                </div>
              <% end %>
            </div>
            <div class="text-sm font-medium">
              <span class="text-slate-900 font-bold">10k+</span> Verifications Completed
            </div>
          </div>
        </div>
        <div class="lg:w-1/2 relative group">
          <div class="absolute -inset-4 bg-teal-500/10 rounded-[2rem] blur-2xl group-hover:bg-teal-500/20 transition-all duration-500"></div>
          <div class="relative glass rounded-[2rem] p-4 p-2 shadow-2xl overflow-hidden">
            <img src="<%= asset_path('hero_verification.png') %>" alt="Verification Interface" class="rounded-xl w-full h-auto shadow-sm">
          </div>
          <!-- Floating UI Elements -->
          <div class="absolute -top-6 -right-6 glass rounded-2xl p-4 shadow-xl animate-bounce" style="animation-duration: 4s;">
            <div class="flex items-center space-x-3">
              <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white">
                <i data-lucide="check" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-xs text-slate-500 font-bold uppercase tracking-wide">Status</div>
                <div class="font-bold text-slate-900">Verified</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trusted By Section -->
  <section class="py-12 border-y border-slate-100 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-center text-sm font-bold text-slate-400 uppercase tracking-[0.2em] mb-10">Trusted by modern enterprises</p>
      <div class="relative overflow-hidden">
        <div class="marquee-content space-x-16">
          <% ["Nexus", "Loom", "Vercel", "Stripe", "Prisma", "Supabase", "Linear", "Attio"].each do |brand| %>
            <div class="flex items-center space-x-3 text-slate-300 hover:text-teal-600 transition-colors cursor-default">
              <i data-lucide="layout" class="w-8 h-8"></i>
              <span class="text-2xl font-black italic tracking-tighter"><%= brand %></span>
            </div>
          <% end %>
          <!-- Repeat for smooth loop -->
          <% ["Nexus", "Loom", "Vercel", "Stripe", "Prisma", "Supabase", "Linear", "Attio"].each do |brand| %>
            <div class="flex items-center space-x-3 text-slate-300 hover:text-teal-600 transition-colors cursor-default">
              <i data-lucide="layout" class="w-8 h-8"></i>
              <span class="text-2xl font-black italic tracking-tighter"><%= brand %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="process" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">Three steps to <span class="text-gradient">Confidence</span></h2>
        <p class="text-lg text-slate-600">Our automated pipeline makes verification seamless for both you and your candidates.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="relative group">
          <div class="w-16 h-16 bg-teal-50 rounded-2xl flex items-center justify-center text-teal-600 mb-8 group-hover:bg-teal-600 group-hover:text-white transition-all duration-300 shadow-sm shadow-premium">
            <i data-lucide="user-plus" class="w-8 h-8"></i>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4">1. Quick Invite</h3>
          <p class="text-slate-600 leading-relaxed">Enter candidate details and send a secure verification invite in one click. No manual paperwork.</p>
          <div class="hidden md:block absolute top-8 left-full w-full h-[2px] bg-slate-100 z-0">
             <div class="h-full bg-teal-500 w-0 group-hover:w-full transition-all duration-1000"></div>
          </div>
        </div>

        <div class="relative group">
          <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-600 mb-8 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300 shadow-sm shadow-premium">
            <i data-lucide="fingerprint" class="w-8 h-8"></i>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4">2. Digital Auth</h3>
          <p class="text-slate-600 leading-relaxed">Candidates authenticate via DigiLocker or SMS and upload documents in a secure, mobile-first flow.</p>
          <div class="hidden md:block absolute top-8 left-full w-full h-[2px] bg-slate-100 z-0">
             <div class="h-full bg-blue-500 w-0 group-hover:w-full transition-all duration-1000"></div>
          </div>
        </div>

        <div class="relative group">
          <div class="w-16 h-16 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600 mb-8 group-hover:bg-purple-600 group-hover:text-white transition-all duration-300 shadow-sm shadow-premium">
            <i data-lucide="award" class="w-8 h-8"></i>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4">3. Verified Report</h3>
          <p class="text-slate-600 leading-relaxed">Receive a detailed, certified verification report in your dashboard. Ready for immediate action.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section id="features" class="py-24 bg-slate-50 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col lg:flex-row items-end justify-between mb-20 gap-8">
        <div class="max-w-2xl">
          <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">Built for the <span class="text-gradient">Modern UI</span></h2>
          <p class="text-lg text-slate-600 leading-relaxed">We provide all the tools you need to manage risk without compromising candidate experience.</p>
        </div>
        <a href="/candidates/sign_up" class="text-teal-600 font-bold flex items-center space-x-2 hover:space-x-4 transition-all">
          <span>Explore all features</span>
          <i data-lucide="arrow-right" class="w-5 h-5"></i>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <% [
          { icon: 'shield-check', title: 'Data Security', desc: 'Enterprise-grade encryption for all candidate data.', color: 'teal' },
          { icon: 'zap', title: 'Instant Pull', desc: 'Direct integration with government data sources.', color: 'blue' },
          { icon: 'smartphone', title: 'Mobile First', desc: 'A frictionless experience on any device.', color: 'purple' },
          { icon: 'database', title: 'History Vault', desc: 'Securely archive and access historical records.', color: 'pink' }
        ].each do |feat| %>
          <div class="glass p-8 rounded-3xl hover-lift border border-slate-100 bg-white/50">
            <div class="w-12 h-12 bg-<%= feat[:color] %>-100 rounded-xl flex items-center justify-center text-<%= feat[:color] %>-600 mb-6">
              <i data-lucide="<%= feat[:icon] %>" class="w-6 h-6"></i>
            </div>
            <h4 class="text-xl font-bold text-slate-900 mb-3"><%= feat[:title] %></h4>
            <p class="text-slate-600 text-sm leading-relaxed"><%= feat[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section id="stats" class="py-24 bg-teal-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-teal-500 via-transparent to-transparent"></div>
    </div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 text-center">
        <div>
          <div class="text-5xl font-black mb-2">99.9%</div>
          <div class="text-teal-300 font-bold uppercase tracking-widest text-xs">Accuracy Rate</div>
        </div>
        <div>
          <div class="text-5xl font-black mb-2">&lt; 2m</div>
          <div class="text-teal-300 font-bold uppercase tracking-widest text-xs">Auth Time</div>
        </div>
        <div>
          <div class="text-5xl font-black mb-2">50+</div>
          <div class="text-teal-300 font-bold uppercase tracking-widest text-xs">Data Sources</div>
        </div>
        <div>
          <div class="text-5xl font-black mb-2">24/7</div>
          <div class="text-teal-300 font-bold uppercase tracking-widest text-xs">Expert Monitoring</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="relative glass bg-teal-900 rounded-[3rem] p-12 lg:p-24 text-center overflow-hidden shadow-2xl">
        <div class="absolute inset-0 bg-gradient-to-br from-teal-600 to-teal-900 opacity-90"></div>
        <div class="relative z-10 max-w-3xl mx-auto">
          <h2 class="text-4xl md:text-6xl font-extrabold text-white mb-8 tracking-tight">Ready to hire with <span class="text-teal-300">confidence?</span></h2>
          <p class="text-xl text-teal-100 mb-12 leading-relaxed">Join 500+ teams that use Truebg to verify their workforce securely and efficiently.</p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/candidates/sign_up" class="w-full sm:w-auto px-10 py-5 rounded-2xl bg-white text-teal-900 font-black text-lg hover:shadow-2xl hover:scale-105 transition-all">
              Create Free Account
            </a>
            <a href="#" class="w-full sm:w-auto px-10 py-5 rounded-2xl border-2 border-teal-500 text-white font-black text-lg hover:bg-teal-500/20 transition-all">
              Talk to Sales
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-white pt-24 pb-12 border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-12 mb-20">
        <div class="col-span-2">
          <a href="#" class="flex items-center space-x-2 mb-8">
            <div class="w-8 h-8 bg-teal-600 rounded-lg flex items-center justify-center text-white">
              <i data-lucide="shield-check" class="w-5 h-5"></i>
            </div>
            <span class="text-xl font-extrabold tracking-tight text-slate-900">Truebg</span>
          </a>
          <p class="text-slate-500 mb-8 max-w-sm">The world's leading infrastructure for background verification.</p>
          <div class="flex items-center space-x-5 text-slate-400">
            <a href="#" class="hover:text-teal-600 transition-colors"><i data-lucide="twitter"></i></a>
            <a href="#" class="hover:text-teal-600 transition-colors"><i data-lucide="linkedin"></i></a>
            <a href="#" class="hover:text-teal-600 transition-colors"><i data-lucide="github"></i></a>
          </div>
        </div>
        <div>
          <h5 class="font-bold text-slate-900 mb-6">Product</h5>
          <ul class="space-y-4 text-slate-500">
            <li><a href="#" class="hover:text-teal-600 transition-colors">Features</a></li>
            <li><a href="#" class="hover:text-teal-600 transition-colors">Integrations</a></li>
            <li><a href="#" class="hover:text-teal-600 transition-colors">Pricing</a></li>
          </ul>
        </div>
        <div>
          <h5 class="font-bold text-slate-900 mb-6">Resources</h5>
          <ul class="space-y-4 text-slate-500">
            <li><a href="#" class="hover:text-teal-600 transition-colors">Documentation</a></li>
            <li><a href="#" class="hover:text-teal-600 transition-colors">API Reference</a></li>
            <li><a href="#" class="hover:text-teal-600 transition-colors">Community</a></li>
          </ul>
        </div>
        <div>
          <h5 class="font-bold text-slate-900 mb-6">Company</h5>
          <ul class="space-y-4 text-slate-500">
            <li><a href="#" class="hover:text-teal-600 transition-colors">About</a></li>
            <li><a href="#" class="hover:text-teal-600 transition-colors">Security</a></li>
            <li><a href="#" class="hover:text-teal-600 transition-colors">Contact</a></li>
          </ul>
        </div>
        <div>
          <h5 class="font-bold text-slate-900 mb-6">Admin</h5>
          <ul class="space-y-4 text-slate-500">
            <li><a href="/admins/sign_in" class="hover:text-teal-600 transition-colors">Admin Login</a></li>
          </ul>
        </div>
      </div>
      <div class="flex flex-col md:flex-row items-center justify-between pt-12 border-t border-slate-100 text-sm text-slate-400">
        <p>&copy; <%= Time.now.year %> Truebg Inc. All rights reserved.</p>
        <div class="flex space-x-8 mt-4 md:mt-0">
          <a href="#" class="hover:text-teal-600 transition-colors">Privacy Policy</a>
          <a href="#" class="hover:text-teal-600 transition-colors">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Modal: Logout Confirmation -->
  <div id="logout-modal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-[1000]">
    <div class="bg-white rounded-[2rem] p-8 w-full max-w-md mx-4 shadow-2xl animate-scale border border-slate-100">
      <div class="w-16 h-16 bg-red-50 rounded-2xl flex items-center justify-center text-red-500 mx-auto mb-6">
        <i data-lucide="log-out" class="w-8 h-8"></i>
      </div>
      <h3 class="text-2xl font-black text-slate-900 mb-4 text-center">Sign Out?</h3>
      <p class="text-slate-500 mb-8 text-center leading-relaxed">Are you sure you want to end your session? You'll need to sign back in to access your dashboard.</p>
      <div class="flex flex-col gap-3">
        <a href="/candidates/sign_out" class="w-full py-4 rounded-2xl bg-slate-900 text-white font-bold text-center hover:bg-red-600 transition-all shadow-lg active:scale-95">
          Yes, Sign Out
        </a>
        <button onclick="logout()" class="w-full py-4 rounded-2xl border border-slate-200 text-slate-600 font-bold hover:bg-slate-50 transition-all active:scale-95">
          Cancel
        </button>
      </div>
    </div>
  </div>

  <script>
    // Initialize Lucide Icons
    lucide.createIcons();

    // Scroll Effects
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('navbar');
      if (window.scrollY > 50) {
        nav.classList.add('py-2');
        nav.querySelector('.max-w-7xl').classList.add('px-4');
      } else {
        nav.classList.remove('py-2');
        nav.querySelector('.max-w-7xl').classList.remove('px-4');
      }
    });

    // Logout Modal
    function logout(){
      document.getElementById('logout-modal').classList.toggle('hidden');
    }
    
    // Close modal on escape
    document.addEventListener('keydown', e => {
      if(e.key === 'Escape') document.getElementById('logout-modal').classList.add('hidden');
    });

    // Background Click Close
    document.getElementById('logout-modal').addEventListener('click', e => {
      if(e.target === e.currentTarget) logout();
    });
  </script>
</body>
</html>

</html>