<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vryfy - Streamlined Background Checks</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="font-sans antialiased text-gray-900 bg-gray-50">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-cyan-300 via-yellow-100 to-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 flex flex-col items-center gap-12">
      <!-- Illustration -->
      <div class="relative z-10">
        <svg width="120" height="120" fill="none" viewBox="0 0 120 120" aria-hidden="true">
          <circle cx="60" cy="60" r="60" fill="#22d3ee" fill-opacity="0.2"/>
          <rect x="38" y="50" width="44" height="28" rx="8" fill="#22d3ee"/>
          <rect x="48" y="62" width="24" height="8" rx="2" fill="#fff"/>
          <circle cx="60" cy="64" r="8" fill="#fff"/>
        </svg>
      </div>
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight mb-6 tracking-tight">
          All Your Background Checks in One Platform
        </h1>
        <p class="text-xl sm:text-2xl text-gray-600 mb-10 max-w-3xl mx-auto">
          Streamline background verifications, HR, and compliance with our secure, automated platform.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#features" class="inline-block px-8 py-3 rounded-full text-white font-semibold bg-cyan-400 hover:bg-cyan-500 shadow-lg transition duration-300 text-lg">Get Started</a>
          <a href="#how-it-works" class="inline-block px-8 py-3 rounded-full text-cyan-400 font-semibold border-2 border-cyan-400 hover:bg-cyan-50 shadow transition duration-300 text-lg bg-white">How It Works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trusted By Section -->
  <section class="bg-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center">
      <span class="uppercase text-sm text-gray-500 tracking-widest mb-6 font-medium">Trusted by Leading Companies</span>
      <div class="flex flex-wrap justify-center gap-8 sm:gap-12 opacity-80">
        <img src="/logos/microsoft.svg" alt="Microsoft" class="h-10 w-auto" loading="lazy">
        <img src="/logos/apple.svg" alt="Apple" class="h-10 w-auto" loading="lazy">
        <img src="/logos/ibm.svg" alt="IBM" class="h-10 w-auto" loading="lazy">
        <img src="/logos/google.svg" alt="Google" class="h-10 w-auto" loading="lazy">
        <img src="/logos/netflix.svg" alt="Netflix" class="h-10 w-auto" loading="lazy">
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section id="features" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h2 class="text-3xl sm:text-4xl font-extrabold text-center text-gray-900 mb-12">Why Choose Vryfy</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-white rounded-2xl shadow-lg p-8 flex flex-col items-center text-center hover:shadow-xl transition duration-300">
        <svg width="48" height="48" fill="none" viewBox="0 0 48 48" class="mb-6" aria-hidden="true">
          <circle cx="24" cy="24" r="24" fill="#22d3ee" fill-opacity="0.2"/>
          <path d="M16 24h16M24 16v16" stroke="#22d3ee" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
        <h3 class="text-xl font-bold mb-3 text-gray-900">Instant Verification</h3>
        <p class="text-gray-600">Complete background checks in minutes with our fully automated workflows.</p>
      </div>
      <div class="bg-white rounded-2xl shadow-lg p-8 flex flex-col items-center text-center hover:shadow-xl transition duration-300">
        <svg width="48" height="48" fill="none" viewBox="0 0 48 48" class="mb-6" aria-hidden="true">
          <circle cx="24" cy="24" r="24" fill="#22d3ee" fill-opacity="0.2"/>
          <path d="M18 30l6-6 6 6" stroke="#22d3ee" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <h3 class="text-xl font-bold mb-3 text-gray-900">Bank-Grade Security</h3>
        <p class="text-gray-600">Your data is protected with end-to-end encryption and strict privacy measures.</p>
      </div>
      <div class="bg-white rounded-2xl shadow-lg p-8 flex flex-col items-center text-center hover:shadow-xl transition duration-300">
        <svg width="48" height="48" fill="none" viewBox="0 0 48 48" class="mb-6" aria-hidden="true">
          <circle cx="24" cy="24" r="24" fill="#22d3ee" fill-opacity="0.2"/>
          <path d="M24 18v12M18 24h12" stroke="#22d3ee" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
        <h3 class="text-xl font-bold mb-3 text-gray-900">Unified Dashboard</h3>
        <p class="text-gray-600">Centralize HR, IT, payroll, and compliance in one intuitive platform.</p>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" class="bg-gray-100 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-center text-gray-900 mb-12">How Vryfy Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="flex flex-col items-center text-center">
          <div class="bg-cyan-100 rounded-full p-5 mb-5">
            <svg width="36" height="36" fill="none" viewBox="0 0 36 36" aria-hidden="true">
              <circle cx="18" cy="18" r="18" fill="#22d3ee" fill-opacity="0.2"/>
              <path d="M12 18h12M18 12v12" stroke="#22d3ee" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h4 class="font-bold text-lg mb-3 text-gray-900">1. Sign Up</h4>
          <p class="text-gray-600 max-w-xs">Create your account in seconds. No credit card required.</p>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="bg-cyan-100 rounded-full p-5 mb-5">
            <svg width="36" height="36" fill="none" viewBox="0 0 36 36" aria-hidden="true">
              <circle cx="18" cy="18" r="18" fill="#22d3ee" fill-opacity="0.2"/>
              <path d="M12 18h12" stroke="#22d3ee" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h4 class="font-bold text-lg mb-3 text-gray-900">2. Add Candidates</h4>
          <p class="text-gray-600 max-w-xs">Upload or invite candidates for seamless background checks.</p>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="bg-cyan-100 rounded-full p-5 mb-5">
            <svg width="36" height="36" fill="none" viewBox="0 0 36 36" aria-hidden="true">
              <circle cx="18" cy="18" r="18" fill="#22d3ee" fill-opacity="0.2"/>
              <path d="M18 12v12" stroke="#22d3ee" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h4 class="font-bold text-lg mb-3 text-gray-900">3. Get Results</h4>
          <p class="text-gray-600 max-w-xs">Access instant, actionable reports in a centralized dashboard.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial Section -->
  <section class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex justify-center mb-8">
        <svg width="48" height="48" fill="none" viewBox="0 0 48 48" aria-hidden="true">
          <circle cx="24" cy="24" r="24" fill="#22d3ee" fill-opacity="0.2"/>
          <path d="M16 32c0-4 4-8 8-8s8 4 8 8" stroke="#22d3ee" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </div>
      <blockquote class="text-2xl sm:text-3xl text-gray-800 font-semibold mb-6 italic">“Vryfy transformed our hiring process, saving us time and ensuring compliance with ease.”</blockquote>
    </div>
  </section>

  <!-- Final Call to Action -->
  <section class="bg-gradient-to-br from-cyan-300 via-yellow-100 to-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-6">Ready to Transform Your HR?</h2>
      <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">Join thousands of companies streamlining background checks and HR workflows with Vryfy.</p>
      <a href="/candidates/sign_up" class="inline-block px-8 py-3 rounded-full text-white font-semibold bg-cyan-400 hover:bg-cyan-500 shadow-lg transition duration-300 text-lg">Create Free Account</a>
    </div>
  </section>
</body>
</html>