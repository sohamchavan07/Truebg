        .header-title {
            font-size: 24px;
            line-height: normal;
            color: black;
        }
        
        .body-text {
            font-size: 16px;
            line-height: 24px;
            color: #333333;
        }
        
        .small-text {
            font-size: 12px;
            line-height: normal;
