<!DOCTYPE html>
<html class="scroll-smooth">
  <head>
    <title>Candidate Operations | Truebg Verification</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "candidate_flow", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <style>
      body { font-family: 'Outfit', sans-serif; }
      .nav-blur { backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
    </style>
  </head>

  <body class="bg-slate-50 min-h-screen text-slate-700 selection:bg-indigo-100 selection:text-indigo-700">
    <% if candidate_signed_in? %>
      <nav class="fixed top-0 left-0 right-0 z-[100] nav-blur bg-white/70 border-b border-slate-100/50">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
          <div class="flex items-center gap-8">
             <div class="text-2xl font-black tracking-tighter text-slate-900 group cursor-default">
              true<span class="text-indigo-600 transition-colors">bg</span>
            </div>
            <div class="hidden md:flex items-center gap-1 bg-slate-100/50 p-1 rounded-2xl border border-slate-200/50">
              <%= link_to candidate_dashboard_path, class: "px-5 py-2 rounded-xl text-sm font-bold transition-all #{request.path == candidate_dashboard_path ? 'bg-white text-indigo-600 shadow-sm border border-slate-100' : 'text-slate-400 hover:text-slate-600 hover:bg-white/50'}" do %>
                Home
              <% end %>
              <div class="w-px h-4 bg-slate-200"></div>
              <%= link_to verifications_review_profile_path, class: "px-5 py-2 rounded-xl text-sm font-bold transition-all #{request.path == verifications_review_profile_path ? 'bg-white text-indigo-600 shadow-sm border border-slate-100' : 'text-slate-400 hover:text-slate-600 hover:bg-white/50'}" do %>
                Verification Status
              <% end %>
            </div>
          </div>

          <div class="flex items-center gap-6">
            <div class="flex items-center gap-3 px-3 py-1.5 bg-slate-50 border border-slate-100 rounded-full">
              <div class="w-7 h-7 rounded-full bg-indigo-600 flex items-center justify-center text-[10px] font-black text-white">
                <%= current_candidate.first_name&.first || current_candidate.email.first.upcase %>
              </div>
              <span class="text-xs font-bold text-slate-600 hidden sm:block"><%= current_candidate.first_name || current_candidate.email.split('@').first %></span>
            </div>
            <%= button_to destroy_candidate_session_path, method: :delete, class: "p-2.5 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-xl transition-all group", title: "Sign Out" do %>
              <svg class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
            <% end %>
          </div>
        </div>
      </nav>
      <div class="pt-28 pb-12">
    <% else %>
      <div class="min-h-screen flex flex-col pt-12">
    <% end %>
      
      <div class="max-w-7xl mx-auto px-6">
        <% if flash[:notice] %>
          <div class="animate-fade-in mb-8 flex items-center gap-4 bg-indigo-50 border border-indigo-100 text-indigo-700 px-6 py-4 rounded-[1.5rem] shadow-xl shadow-indigo-100/20" role="alert">
            <div class="p-2 bg-white rounded-xl shadow-sm">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <span class="text-sm font-bold tracking-tight"><%= flash[:notice] %></span>
          </div>
        <% end %>
        
        <% if flash[:alert] %>
          <div class="animate-fade-in mb-8 flex items-center gap-4 bg-rose-50 border border-rose-100 text-rose-700 px-6 py-4 rounded-[1.5rem] shadow-xl shadow-rose-100/20" role="alert">
             <div class="p-2 bg-white rounded-xl shadow-sm">
              <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <span class="text-sm font-bold tracking-tight"><%= flash[:alert] %></span>
          </div>
        <% end %>

        <%= yield %>
      </div>
      
      <footer class="mt-20 py-12 border-t border-slate-100 text-center">
        <div class="text-2xl font-black tracking-tighter text-slate-300 mb-6 flex items-center justify-center gap-2">
          true<span class="text-slate-200">bg</span>
          <span class="text-[10px] font-black uppercase tracking-[0.3em] ml-2 text-slate-300 italic">Enterprise Grade Verification</span>
        </div>
        <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 mb-8">
          <a href="#" class="text-xs font-bold text-slate-400 hover:text-indigo-600 transition-colors uppercase tracking-[0.2em]">Contact Engineering</a>
          <a href="#" class="text-xs font-bold text-slate-400 hover:text-indigo-600 transition-colors uppercase tracking-[0.2em]">Security Protocol</a>
          <a href="#" class="text-xs font-bold text-slate-400 hover:text-indigo-600 transition-colors uppercase tracking-[0.2em]">Privacy Shield</a>
        </div>
        <p class="text-[10px] font-black text-slate-300 uppercase tracking-widest">&copy; <%= Time.current.year %> Truebg Global Operations. All Rights Reserved.</p>
      </footer>
    </div>
  </body>
</html>
