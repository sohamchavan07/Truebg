<div class="container mx-auto px-4 py-8">
  <div class="max-w-md w-full mx-auto px-4">
    <div class="bg-white p-8 rounded-lg shadow-sm">
      <div class="text-center mb-8">
        <h1 class="text-5xl font-extrabold tracking-tight bg-gradient-to-r from-blue-600 to-blue-800 bg-clip-text text-transparent hover:scale-105 transition-transform duration-300">Verifast</h1>
        <h2 class="mt-4 text-2xl font-semibold text-gray-900">Forgot your password?</h2>
        <p class="mt-2 text-sm text-gray-600">
          Don't worry! Enter your email address and we'll send you instructions to reset your password.
        </p>
      </div>

      <% if flash[:alert] %>
        <div class="mb-6 p-4 rounded-lg border-l-4 border-red-500 bg-red-50 animate-fade-in">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-red-800"><%= flash[:alert] %></p>
            </div>
          </div>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <div class="space-y-6">
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
                  class: "block w-full px-3 py-2 border border-gray-300 rounded shadow-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>
            </div>
          </div>

          <div class="flex justify-center w-full">
            <%= f.submit "Reset Password", 
                class: "w-1/4 flex justify-center py-2 px-4 border border-transparent rounded-full shadow-sm text-sm font-medium text-black",
                style: "background-color: #66FFFF; border-radius: 9999px;"
            %>
          </div>
        </div>
      <% end %>

      <div class="mt-6 text-center">
        <p class="text-sm text-gray-600">Remember your password?</p>
        <div class="flex justify-center w-full">
          <%= link_to "Sign in", new_session_path(resource_name), 
              class: "w-1/4 flex justify-center py-2 px-4 border border-gray-300 rounded-full shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500" %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}
</style>


<%= render "candidates/shared/links" %>
