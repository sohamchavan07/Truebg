<div class="min-h-screen bg-slate-50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <!-- Decorative Background elements -->
  <div class="absolute top-0 left-0 -ml-20 -mt-20 w-96 h-96 bg-blue-100 rounded-full blur-3xl opacity-50"></div>
  <div class="absolute bottom-0 right-0 -mr-20 -mb-20 w-96 h-96 bg-indigo-100 rounded-full blur-3xl opacity-50"></div>

  <div class="max-w-md w-full relative z-10">
    <div class="text-center mb-10 animate-fade-in">
       <div class="inline-flex items-center justify-center p-4 bg-white rounded-3xl shadow-xl shadow-blue-100 border border-blue-50 mb-6 group transition-transform hover:scale-110 duration-500">
        <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A10.003 10.003 0 0012 3a9.99 9.99 0 00-4.556 1.088m.054 15.843l2.853-2.853m0 0A7.5 7.5 0 1112 4.5a7.5 7.5 0 01-1.643 14.571l-2.853 2.853"></path></svg>
      </div>
      <h1 class="text-4xl font-black tracking-tight text-slate-900 mb-2">truebg</h1>
      <h2 class="text-xl font-bold text-slate-600">Change your password</h2>
      <p class="mt-2 text-sm text-slate-400">Create a secure new password for your account</p>
    </div>

    <div class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] p-10 shadow-2xl shadow-blue-100/50 border border-white relative">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
        <%= render "candidates/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="group">
          <%= f.label :password, "New Password", class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 mb-2 group-focus-within:text-blue-500 transition-colors" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            <%= f.password_field :password, autofocus: true, autocomplete: "new-password", required: true,
                class: "block w-full pl-12 pr-4 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all text-slate-700", placeholder: "••••••••" %>
          </div>
          <% if @minimum_password_length %>
            <p class="mt-2 text-[10px] text-slate-400 font-medium pl-1 italic">Min. <%= @minimum_password_length %> characters recommended</p>
          <% end %>
        </div>

        <div class="group">
          <%= f.label :password_confirmation, "Confirm New Password", class: "block text-xs font-bold text-slate-400 uppercase tracking-widest pl-1 mb-2 group-focus-within:text-blue-500 transition-colors" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true,
                class: "block w-full pl-12 pr-4 py-4 bg-slate-50/50 border border-slate-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all text-slate-700", placeholder: "••••••••" %>
          </div>
        </div>

        <div class="pt-4">
          <%= f.submit "Update Password", 
              class: "w-full py-4 px-6 text-white bg-blue-600 hover:bg-slate-900 font-bold rounded-2xl shadow-lg shadow-blue-100 transition-all transform hover:-translate-y-0.5 active:translate-y-0 cursor-pointer flex items-center justify-center gap-2 group" %>
        </div>
      <% end %>

      <div class="mt-8 text-center pt-8 border-t border-slate-50">
        <%= link_to "Back to Sign In", new_session_path(resource_name), class: "text-sm font-bold text-blue-600 hover:text-blue-700 transition-colors" %>
      </div>
    </div>

    <p class="text-center text-[10px] text-slate-400 mt-12 uppercase tracking-[0.2em] font-bold">
      Encrypted with AES-256 Bit Security
    </p>
  </div>
</div>

<style>
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
</style>
