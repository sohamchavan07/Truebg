<div class="max-w-6xl mx-auto py-12 px-4 animate-fade-in">
  <!-- Welcome Section -->
  <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div>
      <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-2">
        Welcome back, <%= @candidate.first_name || "Candidate" %>!
      </h1>
      <p class="text-lg text-slate-500 font-medium">Tracking your premium verification journey.</p>
    </div>
    <div class="flex items-center gap-3 px-4 py-2 bg-white rounded-2xl shadow-sm border border-slate-100">
      <span class="text-xs font-black text-slate-400 uppercase tracking-widest leading-none">Case ID:</span>
      <span class="text-sm font-bold text-indigo-600">#<%= @verification_case&.token&.first(8) || "N/A" %></span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
    <!-- Main Progress Cards -->
    <div class="lg:col-span-8 space-y-10">
      
      <!-- Next Action Card -->
      <div class="bg-slate-900 rounded-[2.5rem] p-10 shadow-2xl relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/20 via-transparent to-purple-600/20 opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
          <div class="text-center md:text-left">
            <span class="inline-block px-3 py-1 bg-indigo-500/20 text-indigo-400 rounded-full text-[10px] font-black uppercase tracking-[0.2em] mb-4">Pending Action</span>
            <h3 class="text-3xl font-black text-white mb-2">Next Step: <%= @next_step[:title] %></h3>
            <p class="text-slate-400 text-sm max-w-sm font-medium">Complete this section to advance your background check process.</p>
          </div>
          <%= link_to @next_step[:path], class: "shrink-0 group/btn inline-flex items-center justify-center px-10 py-5 font-black text-white bg-indigo-600 rounded-[1.5rem] overflow-hidden transition-all hover:scale-105 active:scale-95 shadow-[0_20px_50px_-15px_rgba(79,70,229,0.5)] border border-indigo-400/30" do %>
            Continue Flow
            <svg class="w-5 h-5 ml-2 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          <% end %>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl hover:shadow-slate-200/50 transition-all">
          <div class="w-12 h-12 bg-green-50 rounded-2xl flex items-center justify-center text-green-600 mb-6">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Identity Status</p>
          <p class="text-2xl font-black text-slate-900"><%= session[:phone_verified] ? 'Verified' : 'Pending' %></p>
        </div>
        
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl hover:shadow-slate-200/50 transition-all">
          <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600 mb-6">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Work History</p>
          <p class="text-2xl font-black text-slate-900"><%= @candidate.work_histories.count %> Entries</p>
        </div>

        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl hover:shadow-slate-200/50 transition-all">
          <div class="w-12 h-12 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600 mb-6">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 14l9-5-9-5-9 5 9 5z"></path></svg>
          </div>
          <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Education</p>
          <p class="text-2xl font-black text-slate-900"><%= @candidate.education_histories.count %> Degrees</p>
        </div>
      </div>
    </div>

    <!-- Sidebar Status Explorer -->
    <div class="lg:col-span-4">
      <div class="bg-white rounded-[2.5rem] p-8 border border-slate-100 shadow-sm">
        <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-8">Verification Pipeline</h4>
        <div class="space-y-8 relative">
          <div class="absolute left-4 top-2 bottom-2 w-0.5 bg-slate-100"></div>

          <div class="relative flex items-center gap-5">
            <div class="w-8 h-8 rounded-full <%= session[:phone_verified] ? 'bg-green-500 text-white' : 'bg-indigo-600 text-white' %> flex items-center justify-center text-[10px] font-black z-10">
              <%= session[:phone_verified] ? '✓' : '1' %>
            </div>
            <div>
              <p class="text-sm font-black text-slate-900">Phone Verification</p>
              <p class="text-[10px] text-slate-400 uppercase font-black tracking-widest"><%= session[:phone_verified] ? 'Complete' : 'In Progress' %></p>
            </div>
          </div>

          <div class="relative flex items-center gap-5">
            <div class="w-8 h-8 rounded-full <%= @candidate.pan_number.present? ? 'bg-green-500 text-white' : 'bg-slate-100 text-slate-300' %> flex items-center justify-center text-[10px] font-black z-10">
              <%= @candidate.pan_number.present? ? '✓' : '2' %>
            </div>
            <div>
              <p class="text-sm font-black text-slate-900">Identity Hook</p>
              <p class="text-[10px] text-slate-400 uppercase font-black tracking-widest">DigiLocker Integration</p>
            </div>
          </div>

          <div class="relative flex items-center gap-5">
            <div class="w-8 h-8 rounded-full <%= @candidate.work_histories.any? ? 'bg-green-500 text-white' : 'bg-slate-100 text-slate-300' %> flex items-center justify-center text-[10px] font-black z-10">
              <%= @candidate.work_histories.any? ? '✓' : '3' %>
            </div>
            <div>
              <p class="text-sm font-black text-slate-900">Professional History</p>
              <p class="text-[10px] text-slate-400 uppercase font-black tracking-widest">Career Mapping</p>
            </div>
          </div>
          
          <div class="relative flex items-center gap-5">
            <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-300 flex items-center justify-center text-[10px] font-black z-10">4</div>
            <div>
              <p class="text-sm font-black text-slate-900">Final Certification</p>
              <p class="text-[10px] text-slate-400 uppercase font-black tracking-widest">Locked Stage</p>
            </div>
          </div>
        </div>

        <div class="mt-12 p-6 bg-slate-50 rounded-2xl border border-slate-100">
          <p class="text-[11px] text-slate-500 italic font-medium leading-relaxed">"Verification status updates in real-time as you complete each lifecycle stage."</p>
        </div>
      </div>
    </div>
  </div>
</div>
