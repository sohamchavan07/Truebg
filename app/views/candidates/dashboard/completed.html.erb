<div class="max-w-5xl mx-auto py-12 px-4 animate-fade-in">
  <!-- Status Header -->
  <div class="mb-12 text-center">
    <div class="inline-flex items-center justify-center p-5 bg-indigo-600 rounded-[2.5rem] shadow-2xl shadow-indigo-200 mb-8 border-4 border-indigo-50">
      <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
    </div>
    <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-4">Under Evaluation</h1>
    <p class="text-lg text-slate-500 max-w-2xl mx-auto font-medium">Your profile has been locked for final audit. Our compliance team is currently verifying your records.</p>
  </div>

  <div class="bg-white/80 backdrop-blur-xl rounded-[3rem] shadow-2xl shadow-indigo-100/30 border border-white overflow-hidden p-12">
    <!-- Live Progress Bar -->
    <div class="mb-16">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-black text-slate-400 uppercase tracking-[0.2em]">Audit Sequence</span>
        <span class="text-xs font-black text-indigo-600 uppercase tracking-widest">75% Verified</span>
      </div>
      <div class="h-4 bg-slate-100 rounded-full overflow-hidden p-1">
        <div class="h-full bg-gradient-to-r from-indigo-500 to-purple-600 rounded-full animate-pulse-slow" style="width: 75%"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Security Status -->
      <div class="space-y-8">
        <div>
          <h3 class="text-xl font-black text-slate-900 mb-6">Security Protocol</h3>
          <div class="space-y-4">
            <div class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100">
              <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-indigo-600 shadow-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              </div>
              <p class="text-xs font-bold text-slate-600">Data Immutable & Locked</p>
            </div>
            <div class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100">
              <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-green-600 shadow-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <p class="text-xs font-bold text-slate-600">Identified via DigiLocker</p>
            </div>
          </div>
        </div>
      </div>

      <!-- What's Next -->
      <div class="bg-indigo-50/50 rounded-[2.5rem] p-8 border border-indigo-100/50">
        <h3 class="text-lg font-black text-slate-900 mb-4">What's Next?</h3>
        <ul class="space-y-4">
          <li class="flex gap-3">
            <span class="text-indigo-600 font-bold">•</span>
            <p class="text-xs text-slate-600 font-medium leading-relaxed">Our team will perform a final audit of your work and academic history.</p>
          </li>
          <li class="flex gap-3">
            <span class="text-indigo-600 font-bold">•</span>
            <p class="text-xs text-slate-600 font-medium leading-relaxed">You will receive an automated email once the verification is complete.</p>
          </li>
          <li class="flex gap-3">
            <span class="text-indigo-600 font-bold">•</span>
            <p class="text-xs text-slate-600 font-medium leading-relaxed">A certified PDF report will be attached to your profile upon success.</p>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-slate-100 text-center">
      <%= link_to verifications_review_profile_path, class: "text-xs font-black text-indigo-600 uppercase tracking-widest hover:text-slate-900 transition-colors" do %>
        View Submitted Records
      <% end %>
    </div>
  </div>
</div>

<style>
.animate-pulse-slow { animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
@keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: .98; } }
</style>
