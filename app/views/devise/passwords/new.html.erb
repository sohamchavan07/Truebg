<div class="min-h-screen bg-gradient-to-br from-cyan-50 via-white to-cyan-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md text-center">
    <div class="flex justify-center">
       <span class="text-3xl font-extrabold text-cyan-500 tracking-tight">truebg</span>
    </div>
    <h2 class="mt-6 text-3xl font-extrabold text-gray-900 tracking-tight">
      Forgot your password?
    </h2>
    <p class="mt-2 text-sm text-gray-600">
      Don't worry! Enter your email and we'll send reset instructions.
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-xl sm:rounded-2xl sm:px-10 border border-gray-100">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", 
              class: "appearance-none block w-full px-3 py-3 border border-gray-300 rounded-xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-cyan-500 focus:border-cyan-500 sm:text-sm transition duration-150",
              placeholder: "you@example.com" %>
        </div>

        <div>
          <%= f.submit "Send reset instructions", 
              class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-lg text-sm font-bold text-white bg-cyan-500 hover:bg-cyan-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-cyan-500 transition duration-150 transform hover:-translate-y-0.5 active:translate-y-0" %>
        </div>
      <% end %>

      <div class="mt-6">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-300"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-500">
              Back to account
            </span>
          </div>
        </div>

        <div class="mt-6 text-center">
          <%= link_to "Return to Sign In", new_session_path(resource_name), 
              class: "font-medium text-cyan-600 hover:text-cyan-500 transition" %>
        </div>
      </div>
    </div>
    
    <div class="mt-8 text-center">
      <p class="text-xs text-gray-500">
        &copy; 2025 truebg. All rights reserved. Secure background verification.
      </p>
    </div>
  </div>
</div>
